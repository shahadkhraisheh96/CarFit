@using CarFitProject.ViewModel
@using CarFitProject.Models.Subscriptions
@model AdminSubscriptionsViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.Subs.Title"].Value;
    var statuses = Enum.GetNames(typeof(SubscriptionStatus));

    string IntervalLabel(PlanBillingInterval i) => i switch
    {
        PlanBillingInterval.Week => SharedLocalizer["Billing.Interval.Week"].Value,
        PlanBillingInterval.Month => SharedLocalizer["Billing.Interval.Month"].Value,
        PlanBillingInterval.Year => SharedLocalizer["Billing.Interval.Year"].Value,
        _ => SharedLocalizer["Billing.Interval.PerPost"].Value
    };

    // Active=green class; Trial=blue / Cancelled+Expired=gray via inline styles that match the
    // admin badge aesthetic (no new CSS file); PastDue=amber class.
    (string Cls, string Style) StatusBadge(SubscriptionStatus s) => s switch
    {
        SubscriptionStatus.Active => ("badge-low", ""),
        SubscriptionStatus.PastDue => ("badge-medium", ""),
        SubscriptionStatus.Trial => ("", "background:rgba(59,130,246,0.15);color:#93c5fd;border:1px solid rgba(59,130,246,0.3);"),
        SubscriptionStatus.Cancelled => ("", "background:rgba(148,163,184,0.15);color:#cbd5e1;border:1px solid rgba(148,163,184,0.3);"),
        _ => ("", "background:rgba(148,163,184,0.12);color:#94a3b8;border:1px solid rgba(148,163,184,0.25);")
    };
}

<div class="row mb-4 align-items-center g-3">
    <div class="col">
        <h2 class="text-white fw-bold mb-1"><i class="fa fa-credit-card me-2 text-primary"></i>@SharedLocalizer["Admin.Subs.Title"]</h2>
        <p class="text-muted mb-0 small">@SharedLocalizer["Admin.Subs.Total"]: <strong class="text-white font-monospace">@Model.Rows.TotalCount</strong></p>
    </div>
</div>




<div class="admin-card mb-3 d-flex flex-wrap gap-2 align-items-center">
    <label class="text-muted small fw-bold mb-0">@SharedLocalizer["Admin.Inv.StatusFilter"]</label>
    <a asp-action="Index" class="btn btn-sm @(string.IsNullOrEmpty(Model.StatusFilter) ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Subs.AllStatuses"]</a>
    @foreach (var s in statuses)
    {
        <a asp-action="Index" asp-route-status="@s" class="btn btn-sm @(Model.StatusFilter == s ? "btn-primary" : "btn-outline-light")">@SharedLocalizer[$"Billing.Status.{s}"]</a>
    }
</div>

<div class="admin-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0 table-hover">
            <thead>
                <tr>
                    <th class="ps-4">@SharedLocalizer["Admin.Subs.Name"]</th>
                    <th>@SharedLocalizer["Admin.Subs.Role"]</th>
                    <th>@SharedLocalizer["Admin.Subs.Plan"]</th>
                    <th>@SharedLocalizer["Admin.Subs.Fee"]</th>
                    <th>@SharedLocalizer["Admin.Subs.Status"]</th>
                    <th>@SharedLocalizer["Admin.Subs.Start"]</th>
                    <th>@SharedLocalizer["Admin.Subs.NextBilling"]</th>
                    <th class="pe-4">@SharedLocalizer["Admin.Subs.LifetimePaid"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">@SharedLocalizer["Admin.Subs.None"]</td></tr>
                }
                else
                {
                    foreach (var r in Model.Rows)
                    {
                        var badge = StatusBadge(r.Status);
                        <tr>
                            <td class="ps-4">
                                <div class="text-white fw-semibold">@r.UserName</div>
                                <div class="text-muted small font-monospace">@r.Email</div>
                            </td>
                            <td>
                                <span class="badge @(r.Role == "Dealer" ? "badge-low" : "badge-medium") text-uppercase">
                                    @(r.Role == "Dealer" ? SharedLocalizer["Admin.Role.Dealer"] : SharedLocalizer["Admin.Role.User"])
                                </span>
                            </td>
                            <td class="text-white">@r.PlanName</td>
                            <td class="text-white font-monospace">
                                @r.FeeJod.ToString("0.###") @SharedLocalizer["Common.JOD"]
                                <span class="text-muted small">/ @IntervalLabel(r.Interval)</span>
                            </td>
                            <td><span class="badge @badge.Cls text-uppercase" style="@badge.Style">@SharedLocalizer[$"Billing.Status.{r.Status}"]</span></td>
                            <td class="text-muted small font-monospace">@r.StartDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-muted small font-monospace">@(r.NextBilling?.ToLocalTime().ToString("yyyy-MM-dd") ?? "—")</td>
                            <td class="pe-4 text-white font-monospace">@r.LifetimePaidJod.ToString("0.###") @SharedLocalizer["Common.JOD"]</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pager" model="@(new CarFitProject.ViewModel.PagerViewModel { Page = Model.Rows.PageIndex, TotalPages = Model.Rows.TotalPages, Action = "Index", Controller = "Subscriptions", RouteValues = new { status = Model.StatusFilter } })" />
