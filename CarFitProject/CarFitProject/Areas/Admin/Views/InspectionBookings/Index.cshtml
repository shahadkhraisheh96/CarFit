@using CarFitProject.ViewModel
@model AdminBookingListViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.Bookings.Title"].Value;
    var statuses = new[] { "Pending", "Confirmed", "Completed", "Cancelled" };

    (string Cls, string Style) StatusBadge(string s) => s switch
    {
        "Completed" => ("badge-low", ""),
        "Pending" => ("badge-medium", ""),
        "Confirmed" => ("", "background:rgba(59,130,246,0.15);color:#93c5fd;border:1px solid rgba(59,130,246,0.3);"),
        _ => ("", "background:rgba(148,163,184,0.15);color:#cbd5e1;border:1px solid rgba(148,163,184,0.3);") // Cancelled
    };
}

<div class="row mb-4 align-items-center g-3">
    <div class="col">
        <h2 class="text-white fw-bold mb-1"><i class="fa fa-clipboard-check me-2 text-primary"></i>@SharedLocalizer["Admin.Bookings.Title"]</h2>
        <p class="text-muted mb-0 small">@SharedLocalizer["Admin.Subs.Total"]: <strong class="text-white font-monospace">@Model.Rows.TotalCount</strong></p>
    </div>
</div>




<div class="admin-card mb-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-sm-6 col-md-3">
            <label class="text-muted small fw-bold d-block mb-1">@SharedLocalizer["Admin.Subs.Status"]</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">@SharedLocalizer["Admin.Inv.All"]</option>
                @foreach (var s in statuses)
                {
                    if (Model.Status == s)
                    {
                        <option value="@s" selected>@SharedLocalizer[$"Admin.Bookings.Status.{s}"]</option>
                    }
                    else
                    {
                        <option value="@s">@SharedLocalizer[$"Admin.Bookings.Status.{s}"]</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-3 col-md-2">
            <label class="text-muted small fw-bold d-block mb-1">@SharedLocalizer["Admin.Bookings.From"]</label>
            <input type="date" name="from" value="@(Model.From?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
        </div>
        <div class="col-sm-3 col-md-2">
            <label class="text-muted small fw-bold d-block mb-1">@SharedLocalizer["Admin.Bookings.To"]</label>
            <input type="date" name="to" value="@(Model.To?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
        </div>
        <div class="col-sm-6 col-md-3">
            <label class="text-muted small fw-bold d-block mb-1">@SharedLocalizer["Admin.Bookings.Search"]</label>
            <input type="text" name="q" value="@Model.Q" placeholder="@SharedLocalizer["Admin.Bookings.SearchPlaceholder"]" class="form-control form-control-sm" />
        </div>
        <div class="col-sm-6 col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary fw-bold flex-grow-1"><i class="fa fa-filter me-1"></i>@SharedLocalizer["Admin.Bookings.Apply"]</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-light">@SharedLocalizer["Admin.Inv.All"]</a>
        </div>
    </form>
</div>

<div class="admin-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0 table-hover">
            <thead>
                <tr>
                    <th class="ps-4">@SharedLocalizer["Admin.Bookings.Id"]</th>
                    <th>@SharedLocalizer["Admin.Bookings.Customer"]</th>
                    <th>@SharedLocalizer["Admin.Bookings.Car"]</th>
                    <th>@SharedLocalizer["Admin.Bookings.Mechanic"]</th>
                    <th>@SharedLocalizer["Admin.Bookings.Scheduled"]</th>
                    <th>@SharedLocalizer["Admin.Subs.Status"]</th>
                    <th>@SharedLocalizer["Admin.Inv.Created"]</th>
                    <th class="text-end pe-4">@SharedLocalizer["Admin.Bookings.Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">@SharedLocalizer["Admin.Bookings.None"]</td></tr>
                }
                else
                {
                    foreach (var b in Model.Rows)
                    {
                        var badge = StatusBadge(b.Status);
                        var car = b.CarListing?.Car;
                        <tr>
                            <td class="ps-4 text-muted font-monospace fw-bold">#@b.Id</td>
                            <td>
                                <div class="text-white fw-semibold">@b.CustomerName</div>
                                <div class="text-muted small font-monospace">@b.CustomerEmail</div>
                            </td>
                            <td>
                                @if (car != null && b.CarListingId.HasValue)
                                {
                                    <a asp-area="" asp-controller="Inventory" asp-action="Detail" asp-route-id="@b.CarListingId" class="text-decoration-none text-primary">
                                        @car.Make @car.Model <span class="text-muted small">@car.Year</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-muted">@(b.Mechanic?.Name ?? "—")</td>
                            <td class="text-muted small font-monospace">@b.PreferredDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td><span class="badge @badge.Cls text-uppercase" style="@badge.Style">@SharedLocalizer[$"Admin.Bookings.Status.{b.Status}"]</span></td>
                            <td class="text-muted small font-monospace">@b.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary fw-bold"><i class="fa fa-eye me-1"></i>@SharedLocalizer["Admin.Bookings.View"]</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pager" model="@(new CarFitProject.ViewModel.PagerViewModel { Page = Model.Rows.PageIndex, TotalPages = Model.Rows.TotalPages, Action = "Index", Controller = "InspectionBookings", RouteValues = new { status = Model.Status, from = Model.From?.ToString("yyyy-MM-dd"), to = Model.To?.ToString("yyyy-MM-dd"), q = Model.Q } })" />
