@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.Tools.Title"].Value;
    var nullCount = (int)(ViewBag.NullPhoneCount ?? 0);
}

<div class="row mb-4 align-items-center g-3">
    <div class="col">
        <h2 class="text-white fw-bold mb-1"><i class="fa-solid fa-screwdriver-wrench me-2 text-primary"></i>@SharedLocalizer["Admin.Tools.Title"]</h2>
    </div>
</div>



<div class="admin-card" style="max-width:680px;">
    <h5 class="text-white fw-bold mb-2"><i class="fa fa-phone me-2 text-primary"></i>@SharedLocalizer["Admin.Tools.Backfill.Heading"]</h5>
    <p class="text-muted mb-3">@string.Format(SharedLocalizer["Admin.Tools.Backfill.Desc"].Value, nullCount)</p>

    @if (nullCount > 0)
    {
        <form asp-action="BackfillPhones" method="post"
              data-confirm="@string.Format(SharedLocalizer["Admin.Tools.Confirm"].Value, nullCount)">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary fw-bold">
                <i class="fa fa-wand-magic-sparkles me-2"></i>@SharedLocalizer["Admin.Tools.Backfill.Button"]
            </button>
        </form>
    }
    else
    {
        <div class="text-muted"><i class="fa fa-circle-check me-1 text-success"></i>@SharedLocalizer["Admin.Tools.None"]</div>
    }
</div>
