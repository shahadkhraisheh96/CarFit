@model List<CarFitProject.Models.Testimonial>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Testimonials";
    var pendingCount = Model.Count(t => !t.IsApproved);
    var approvedCount = Model.Count(t => t.IsApproved);
}

<style>
    .widescreen-wrapper { width: 100% !important; padding: 0 !important; margin: 0 !important; }
    .custom-user-table th {
        font-weight: 600; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05rem;
        background-color: var(--bg-sidebar) !important; border-bottom: 1px solid var(--border-dim) !important; padding: 14px 12px !important;
    }
    .custom-user-table td { border-bottom: 1px solid var(--border-dim) !important; padding: 1rem 0.75rem !important; }
    .review-stars i { color: #f59e0b; }
    .review-stars i.empty { color: rgba(255,255,255,0.18); }
    .review-text-cell { max-width: 420px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                <div>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none text-primary small d-inline-block mb-2 fw-bold">
                        <i class="fa fa-arrow-left me-1"></i> Back to Control Base
                    </a>
                    <h2 class="text-white fw-bold mb-1">
                        <i class="fa-solid fa-comment-dots me-2 text-primary"></i>Testimonials Management
                    </h2>
                    <p class="text-muted mb-0 small">
                        Every website review. Approve pending ones to publish them, or delete any review.
                        Total: <strong class="text-white font-monospace">@Model.Count</strong>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <span class="badge badge-medium px-3 py-2 text-uppercase tracking-wider" style="font-size: 0.75rem;">@pendingCount Pending</span>
                    <span class="badge badge-low px-3 py-2 text-uppercase tracking-wider" style="font-size: 0.75rem;">@approvedCount Approved</span>
                </div>
            </div>
        </div>
    </div>

    
    

    <div class="row">
        <div class="col-12">
            <div class="admin-card p-0 overflow-hidden shadow-sm">
                <div class="py-3 px-4 border-bottom d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.15); border-color: var(--border-dim) !important;">
                    <h5 class="mb-0 fw-bold text-white fs-6"><i class="fa-solid fa-list-check me-2 text-primary"></i>All Reviews</h5>
                    <span class="badge badge-low font-monospace">@Model.Count Total</span>
                </div>
                <div class="table-responsive">
                    <table class="table text-start align-middle mb-0 table-hover w-100 custom-user-table">
                        <thead>
                            <tr>
                                <th class="ps-4">Reviewer</th>
                                <th>Rating</th>
                                <th>Review</th>
                                <th class="text-center">Status</th>
                                <th class="text-center pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fa fa-comment-slash fs-2 mb-3 d-block text-primary opacity-25"></i>
                                        No testimonials submitted yet.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var review in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="text-white fw-semibold">@review.ReviewerName</div>
                                            <div class="text-muted small">@review.CreatedDate.ToString("yyyy-MM-dd")</div>
                                        </td>
                                        <td>
                                            <div class="review-stars" title="@review.Rating / 5">
                                                @for (var i = 1; i <= 5; i++)
                                                {
                                                    <i class="fa-solid fa-star @(i <= review.Rating ? "" : "empty")"></i>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-white-50 review-text-cell" title="@review.ReviewText">@review.ReviewText</td>
                                        <td class="text-center">
                                            @if (review.IsApproved)
                                            {
                                                <span class="badge badge-low"><i class="fa fa-circle-check me-1"></i>Approved</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-medium"><i class="fa fa-clock me-1"></i>Pending</span>
                                            }
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="d-inline-flex gap-2">
                                                <a asp-action="Details" asp-route-id="@review.Id" class="btn btn-sm btn-outline-light fw-bold">
                                                    <i class="fa fa-eye me-1"></i>View
                                                </a>
                                                @if (!review.IsApproved)
                                                {
                                                    <form asp-action="Approve" method="post" class="m-0">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@review.Id" />
                                                        <button type="submit" class="btn btn-sm btn-success fw-bold">
                                                            <i class="fa fa-check me-1"></i>Approve
                                                        </button>
                                                    </form>
                                                }
                                                <form asp-action="Delete" method="post" class="m-0" data-confirm="Delete this testimonial permanently?">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@review.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                                                        <i class="fa fa-xmark me-1"></i>Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
