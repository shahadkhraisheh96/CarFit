@model CarFitProject.Models.Testimonial
@{
    Layout = "_Layout";
    ViewData["Title"] = "Testimonial Details";
}

<style>
    .widescreen-wrapper { width: 100% !important; padding: 0 !important; margin: 0 !important; }
    .review-stars i { color: #f59e0b; font-size: 1.25rem; }
    .review-stars i.empty { color: rgba(255,255,255,0.18); }
    .detail-label { text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05rem; color: var(--text-muted); font-weight: 600; }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card">
                <a asp-area="Admin" asp-controller="Testimonials" asp-action="Index" class="text-decoration-none text-primary small d-inline-block mb-2 fw-bold">
                    <i class="fa fa-arrow-left me-1"></i> Back to Testimonials
                </a>
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                    <h2 class="text-white fw-bold mb-0">
                        <i class="fa-solid fa-comment-dots me-2 text-primary"></i>Review Details
                    </h2>
                    @if (Model.IsApproved)
                    {
                        <span class="badge badge-low px-3 py-2"><i class="fa fa-circle-check me-1"></i>Approved</span>
                    }
                    else
                    {
                        <span class="badge badge-medium px-3 py-2"><i class="fa fa-clock me-1"></i>Pending</span>
                    }
                </div>
            </div>
        </div>
    </div>

    

    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="admin-card h-100">
                <div class="mb-4">
                    <div class="detail-label mb-1">Reviewer</div>
                    <div class="text-white fw-semibold fs-5">@Model.ReviewerName</div>
                </div>
                <div class="mb-4">
                    <div class="detail-label mb-1">Rating</div>
                    <div class="review-stars" title="@Model.Rating / 5">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <i class="fa-solid fa-star @(i <= Model.Rating ? "" : "empty")"></i>
                        }
                        <span class="text-white-50 ms-2 font-monospace">@Model.Rating / 5</span>
                    </div>
                </div>
                <div>
                    <div class="detail-label mb-1">Review</div>
                    <p class="text-white-50 mb-0" style="white-space: pre-wrap;">@Model.ReviewText</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="admin-card h-100 d-flex flex-column">
                <div class="mb-3">
                    <div class="detail-label mb-1">Submitted</div>
                    <div class="text-white font-monospace">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
                <div class="mb-4">
                    <div class="detail-label mb-1">Submitting User Id</div>
                    <div class="text-white-50 small font-monospace text-break">@(string.IsNullOrEmpty(Model.UserId) ? "—" : Model.UserId)</div>
                </div>

                <div class="mt-auto d-flex flex-column gap-2">
                    @if (!Model.IsApproved)
                    {
                        <form asp-action="Approve" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success fw-bold w-100">
                                <i class="fa fa-check me-1"></i>Approve
                            </button>
                        </form>
                    }
                    <form asp-action="Delete" method="post" class="m-0" data-confirm="Delete this testimonial permanently?">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger fw-bold w-100">
                            <i class="fa fa-xmark me-1"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
