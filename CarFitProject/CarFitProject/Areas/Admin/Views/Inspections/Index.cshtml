@model CarFitProject.Helpers.PaginatedList<CarFitProject.Models.CarListing>
@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.Insp.Title"].Value;
    var has = ViewBag.HasFilter as string;
}

<div class="row mb-4 align-items-center g-3">
    <div class="col">
        <h2 class="text-white fw-bold mb-1"><i class="fa-solid fa-clipboard-check me-2 text-primary"></i>@SharedLocalizer["Admin.Insp.Title"]</h2>
        <p class="text-muted mb-0 small">@SharedLocalizer["Admin.Subs.Total"]: <strong class="text-white font-monospace">@Model.TotalCount</strong></p>
    </div>
</div>




<div class="admin-card mb-3 d-flex flex-wrap gap-2 align-items-center">
    <label class="text-muted small fw-bold mb-0">@SharedLocalizer["Admin.Insp.Filter"]</label>
    <a asp-action="Index" class="btn btn-sm @(string.IsNullOrEmpty(has) ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Inv.All"]</a>
    <a asp-action="Index" asp-route-has="yes" class="btn btn-sm @(has == "yes" ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Insp.With"]</a>
    <a asp-action="Index" asp-route-has="no" class="btn btn-sm @(has == "no" ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Insp.Without"]</a>
</div>

<div class="admin-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0 table-hover">
            <thead>
                <tr>
                    <th class="ps-4">@SharedLocalizer["Admin.Insp.Car"]</th>
                    <th>@SharedLocalizer["Admin.Inv.Seller"]</th>
                    <th>@SharedLocalizer["Admin.Insp.Report"]</th>
                    <th>@SharedLocalizer["Admin.Insp.Date"]</th>
                    <th class="text-end pe-4">@SharedLocalizer["Admin.Bookings.Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center py-5 text-muted">@SharedLocalizer["Admin.Insp.Empty"]</td></tr>
                }
                else
                {
                    foreach (var l in Model)
                    {
                        var report = l.Car?.InspectionReport;
                        <tr>
                            <td class="ps-4 text-white fw-semibold">@l.Car?.Make @l.Car?.Model <span class="text-muted small">@l.Car?.Year</span></td>
                            <td class="text-muted">@(l.Seller?.Name ?? "—")</td>
                            <td>
                                @if (report != null)
                                {
                                    <span class="badge badge-low text-uppercase">@(report.OverallScore?.ToString("0.0") ?? "✓")</span>
                                    @if (report.CarseerAttached == true)
                                    {
                                        <span class="badge bg-info text-white ms-1"><i class="fa-solid fa-shield-halved me-1"></i>CarSeer</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge badge-critical text-uppercase">@SharedLocalizer["Admin.Insp.None"]</span>
                                }
                            </td>
                            <td class="text-muted small font-monospace">@(report?.InspectionDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            <td class="text-end pe-4">
                                <div class="d-inline-flex gap-2 justify-content-end flex-wrap">
                                    @if (report != null && l.CarId.HasValue)
                                    {
                                        <a href="/Inspection/Pdf/@l.CarId" target="_blank" rel="noopener" class="btn btn-sm btn-outline-danger fw-bold">
                                            <i class="fa fa-file-pdf me-1"></i>PDF
                                        </a>
                                    }
                                    @if (l.CarId.HasValue)
                                    {
                                        <a asp-action="Edit" asp-route-carId="@l.CarId" class="btn btn-sm btn-outline-primary fw-bold">
                                            <i class="fa fa-pen me-1"></i>@SharedLocalizer["Admin.Insp.Edit"]
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pager" model="@(new CarFitProject.ViewModel.PagerViewModel { Page = Model.PageIndex, TotalPages = Model.TotalPages, Action = "Index", Controller = "Inspections", RouteValues = new { has = has } })" />
