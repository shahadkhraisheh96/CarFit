@using CarFitProject.Helpers
@model PaginatedList<CarFitProject.Models.ContactMessage>

@{
    ViewData["Title"] = "Contact Messages";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="mb-1 fw-bold">Contact Messages</h3>
        <p class="text-muted mb-0">View messages sent from the Contact Us page.</p>
    </div>
</div>

<div class="bg-secondary rounded p-4 shadow-sm border border-dark">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-envelope-open text-muted mb-3" style="font-size:3rem;"></i>
            <h5 class="text-white">No messages yet</h5>
            <p class="text-white-50">When users submit contact forms, they will appear here.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table text-start align-middle table-hover mb-0">
                <thead>
                    <tr class="text-white">
                        <th scope="col">Status</th>
                        <th scope="col">Date</th>
                        <th scope="col">Name</th>
                        <th scope="col">Subject</th>
                        <th scope="col" style="width:35%;">Message</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var isNew = item.Status == "New";
                        <tr>
                            <td>
                                @if (isNew)
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2 fw-bold"><i class="fa-solid fa-envelope me-1"></i> New</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill border border-secondary px-3 py-2 text-white-50"><i class="fa-solid fa-envelope-open me-1"></i> Read</span>
                                }
                            </td>
                            <td>
                                <div class="fw-bold @(isNew ? "text-white" : "text-white-50")">@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                <div class="small text-muted">@item.CreatedAt.ToLocalTime().ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                <div class="fw-bold @(isNew ? "text-white" : "text-white-50")">@item.Name</div>
                                <div class="small text-muted"><a href="mailto:@item.Email" class="text-info text-decoration-none">@item.Email</a></div>
                            </td>
                            <td>
                                <div class="@(isNew ? "text-white fw-bold" : "text-white-50")">@(string.IsNullOrEmpty(item.Subject) ? "(No Subject)" : item.Subject)</div>
                            </td>
                            <td>
                                <div class="text-truncate" style="max-width: 300px;" title="@item.Message">
                                    <small class="@(isNew ? "text-white" : "text-white-50")">@item.Message</small>
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#messageModal-@item.Id">
                                        <i class="fa-solid fa-eye"></i> View
                                    </button>
                                    <form method="post" asp-action="Delete" asp-route-id="@item.Id" data-confirm="Are you sure you want to delete this message?">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>

                                <!-- View Modal -->
                                <div class="modal fade" id="messageModal-@item.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content bg-secondary text-start">
                                            <div class="modal-header border-bottom border-dark">
                                                <h5 class="modal-title">Message Details</h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <div class="mb-3">
                                                    <label class="text-muted small mb-1">From</label>
                                                    <div class="fw-bold text-white">@item.Name &lt;<a href="mailto:@item.Email" class="text-info text-decoration-none">@item.Email</a>&gt;</div>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="text-muted small mb-1">Date</label>
                                                    <div class="text-white">@item.CreatedAt.ToLocalTime().ToString("f")</div>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="text-muted small mb-1">Subject</label>
                                                    <div class="text-white fw-bold">@(string.IsNullOrEmpty(item.Subject) ? "(No Subject)" : item.Subject)</div>
                                                </div>
                                                <div class="mb-0">
                                                    <label class="text-muted small mb-1">Message</label>
                                                    <div class="p-3 bg-dark rounded text-white" style="white-space: pre-wrap;">@item.Message</div>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-top border-dark d-flex justify-content-between">
                                                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                                                @if (isNew)
                                                {
                                                    <form method="post" asp-action="MarkRead" asp-route-id="@item.Id">
                                                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-2"></i>Mark as Read</button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link bg-dark border-dark text-white" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link @(i == Model.PageIndex ? "bg-primary border-primary" : "bg-dark border-dark text-white")" asp-action="Index" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link bg-dark border-dark text-white" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>
