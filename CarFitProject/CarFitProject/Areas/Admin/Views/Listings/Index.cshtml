@model CarFitProject.Helpers.PaginatedList<CarFitProject.Models.CarListing>
@{
    Layout = "_Layout";
    ViewData["Title"] = SharedLocalizer["Admin.Listings.Title"].Value;
    var statusFilter = ViewBag.StatusFilter as string;
    var sellerType = ViewBag.SellerType as string;
    var condition = ViewBag.Condition as string;

    bool IsPrivate(CarFitProject.Models.CarListing l) => l.Seller?.Type == "Private";
    string? PrimaryImage(CarFitProject.Models.CarListing l) =>
        l.Car?.CarImages?
            .OrderByDescending(i => i.IsPrimary).ThenBy(i => i.SortOrder)
            .FirstOrDefault()?.Url;
}

<div class="row mb-4 align-items-center g-3">
    <div class="col">
        <h2 class="text-white fw-bold mb-1"><i class="fa fa-car me-2 text-primary"></i>All Listings </h2>
        <p class="text-muted mb-0 small">Total: <strong class="text-white font-monospace">@Model.TotalCount</strong> listings.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-primary fw-bold"><i class="fa fa-plus me-1"></i>Add listing</a>
    </div>
</div>




<div class="admin-card mb-3 d-flex flex-wrap gap-3 align-items-center">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <label class="text-muted small fw-bold mb-0">@SharedLocalizer["Admin.Inv.StatusFilter"]</label>
        <a asp-action="Index" asp-route-sellerType="@sellerType" asp-route-condition="@condition" class="btn btn-sm @(string.IsNullOrEmpty(statusFilter) ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Inv.All"]</a>
        <a asp-action="Index" asp-route-status="@CarFitProject.Models.ListingStatus.PendingInspectionReview" asp-route-sellerType="@sellerType" asp-route-condition="@condition" class="btn btn-sm @(statusFilter == CarFitProject.Models.ListingStatus.PendingInspectionReview ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Listing.Status.PendingInspectionReview"]</a>
        <a asp-action="Index" asp-route-status="@CarFitProject.Models.ListingStatus.Approved" asp-route-sellerType="@sellerType" asp-route-condition="@condition" class="btn btn-sm @(statusFilter == CarFitProject.Models.ListingStatus.Approved ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Listing.Status.Approved"]</a>
        <a asp-action="Index" asp-route-status="@CarFitProject.Models.ListingStatus.Rejected" asp-route-sellerType="@sellerType" asp-route-condition="@condition" class="btn btn-sm @(statusFilter == CarFitProject.Models.ListingStatus.Rejected ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Listing.Status.Rejected"]</a>
        <a asp-action="Index" asp-route-status="@CarFitProject.Models.ListingStatus.Sold" asp-route-sellerType="@sellerType" asp-route-condition="@condition" class="btn btn-sm @(statusFilter == CarFitProject.Models.ListingStatus.Sold ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Listing.Status.Sold"]</a>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <label class="text-muted small fw-bold mb-0">@SharedLocalizer["Admin.Inv.SellerFilter"]</label>
        <a asp-action="Index" asp-route-status="@statusFilter" asp-route-condition="@condition" class="btn btn-sm @(string.IsNullOrEmpty(sellerType) ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Inv.All"]</a>
        <a asp-action="Index" asp-route-status="@statusFilter" asp-route-condition="@condition" asp-route-sellerType="User" class="btn btn-sm @(sellerType == "User" ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Role.User"]</a>
        <a asp-action="Index" asp-route-status="@statusFilter" asp-route-condition="@condition" asp-route-sellerType="Dealer" class="btn btn-sm @(sellerType == "Dealer" ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Role.Dealer"]</a>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <label class="text-muted small fw-bold mb-0">@SharedLocalizer["Admin.Inv.ConditionFilter"]</label>
        <a asp-action="Index" asp-route-status="@statusFilter" asp-route-sellerType="@sellerType" class="btn btn-sm @(string.IsNullOrEmpty(condition) ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Admin.Inv.All"]</a>
        <a asp-action="Index" asp-route-status="@statusFilter" asp-route-sellerType="@sellerType" asp-route-condition="New" class="btn btn-sm @(condition == "New" ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Listing.Condition.New"]</a>
        <a asp-action="Index" asp-route-status="@statusFilter" asp-route-sellerType="@sellerType" asp-route-condition="Used" class="btn btn-sm @(condition == "Used" ? "btn-primary" : "btn-outline-light")">@SharedLocalizer["Listing.Condition.Used"]</a>
    </div>
</div>

<div class="admin-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">@SharedLocalizer["Admin.Inv.Image"]</th>
                    <th>Vehicle</th>
                    <th>@SharedLocalizer["Admin.Inv.Seller"]</th>
                    <th>@SharedLocalizer["Admin.Inv.SellerRole"]</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>@SharedLocalizer["Admin.Inv.Created"]</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">No listings match this filter.</td></tr>
                }
                else
                {
                    foreach (var l in Model)
                    {
                        var img = PrimaryImage(l);
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(img))
                                {
                                    <img src="@img" alt="" style="width:56px;height:42px;object-fit:cover;border-radius:6px;" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center text-muted" style="width:56px;height:42px;border-radius:6px;background:rgba(255,255,255,0.05);"><i class="fa fa-car"></i></span>
                                }
                            </td>
                            <td class="text-white fw-semibold">@l.Car?.Make @l.Car?.Model <span class="text-muted small">@l.Car?.Year</span></td>
                            <td class="text-muted">@(l.Seller?.Name ?? "—")</td>
                            <td>
                                @if (IsPrivate(l))
                                {
                                    <span class="badge badge-medium text-uppercase">@SharedLocalizer["Admin.Role.User"]</span>
                                }
                                else
                                {
                                    <span class="badge badge-low text-uppercase">@SharedLocalizer["Admin.Role.Dealer"]</span>
                                }
                            </td>
                            <td class="text-white font-monospace">@(l.ListingPrice?.ToString("N0")) JD</td>
                            <td>
                                @switch (l.Status)
                                {
                                    case CarFitProject.Models.ListingStatus.Approved:
                                        <span class="badge badge-low text-uppercase">@SharedLocalizer["Listing.Status.Approved"]</span>
                                        break;
                                    case CarFitProject.Models.ListingStatus.PendingInspectionReview:
                                        <span class="badge badge-medium text-uppercase">@SharedLocalizer["Listing.Status.PendingInspectionReview"]</span>
                                        break;
                                    case CarFitProject.Models.ListingStatus.Rejected:
                                        <span class="badge badge-critical text-uppercase">@SharedLocalizer["Listing.Status.Rejected"]</span>
                                        break;
                                    case CarFitProject.Models.ListingStatus.Sold:
                                        <span class="badge badge-medium text-uppercase">@SharedLocalizer["Listing.Status.Sold"]</span>
                                        break;
                                    case CarFitProject.Models.ListingStatus.Draft:
                                        <span class="badge badge-low text-uppercase">@SharedLocalizer["Listing.Status.Draft"]</span>
                                        break;
                                    default:
                                        <span class="badge badge-critical text-uppercase">@l.Status</span>
                                        break;
                                }
                            </td>
                            <td class="text-muted small font-monospace">@l.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-end pe-4">
                                <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                    @if (l.Status == CarFitProject.Models.ListingStatus.PendingInspectionReview)
                                    {
                                        <a asp-action="Review" asp-route-id="@l.Id" class="btn btn-sm btn-success fw-bold"><i class="fa fa-clipboard-check me-1"></i>@SharedLocalizer["Admin.Listings.ReviewBtn"]</a>
                                    }
                                    <a asp-action="Edit" asp-route-id="@l.Id" class="btn btn-sm btn-outline-primary fw-bold"><i class="fa fa-pen me-1"></i>Edit</a>
                                    @if (l.CarId.HasValue)
                                    {
                                        <a asp-controller="Inspections" asp-action="Edit" asp-route-carId="@l.CarId" class="btn btn-sm btn-outline-info fw-bold">
                                            <i class="fa fa-clipboard-check me-1"></i>Inspection
                                        </a>
                                    }
                                    <form asp-action="Delete" method="post" class="m-0"
                                          data-confirm="Remove this listing permanently?">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@l.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold"><i class="fa fa-trash me-1"></i>Remove</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_Pager" model="@(new CarFitProject.ViewModel.PagerViewModel { Page = Model.PageIndex, TotalPages = Model.TotalPages, Action = "Index", Controller = "Listings", RouteValues = new { status = statusFilter, sellerType = sellerType, condition = condition } })" />
