@model CarFitProject.ViewModel.ListingReviewViewModel
@{
    Layout = "_Layout";
    var car = Model.Listing.Car!;
    ViewData["Title"] = $"{car.Year} {car.Make} {car.Model}";
    var images = car.CarImages?.OrderByDescending(i => i.IsPrimary).ThenBy(i => i.SortOrder).ToList() ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-action="Index" class="text-decoration-none small fw-bold text-primary"><i class="fa fa-arrow-left me-1"></i>@SharedLocalizer["Admin.Review.Back"]</a>
        <h2 class="text-white fw-bold mb-0 mt-2">@car.Year @car.Make @car.Model</h2>
    </div>
    <div>
        @if (Model.IsUsed)
        {
            <span class="badge badge-medium text-uppercase">@SharedLocalizer["Listing.Condition.Used"]</span>
        }
        else
        {
            <span class="badge badge-low text-uppercase">@SharedLocalizer["Listing.Condition.New"]</span>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="admin-card mb-4">
            <h5 class="text-white fw-bold mb-3">@SharedLocalizer["Admin.Review.VehicleDetails"]</h5>
            <dl class="row text-muted small mb-0">
                <dt class="col-4">@SharedLocalizer["Listing.Condition.Label"]</dt><dd class="col-8 text-white">@car.Type</dd>
                <dt class="col-4">Trim</dt><dd class="col-8 text-white">@(car.Trim ?? "—")</dd>
                <dt class="col-4">Transmission</dt><dd class="col-8 text-white">@(car.Transmission ?? "—")</dd>
                <dt class="col-4">Mileage</dt><dd class="col-8 text-white">@(car.Kilometers ?? "—")</dd>
                <dt class="col-4">Engine</dt><dd class="col-8 text-white">@(car.EngineSize ?? "—")</dd>
                <dt class="col-4">Fuel</dt><dd class="col-8 text-white">@(car.FuelType ?? "—")</dd>
                <dt class="col-4">Body</dt><dd class="col-8 text-white">@(car.BodyType ?? "—")</dd>
                <dt class="col-4">Seats</dt><dd class="col-8 text-white">@(car.Seats?.ToString() ?? "—")</dd>
                <dt class="col-4">Listing price</dt><dd class="col-8 text-white">@(Model.Listing.ListingPrice?.ToString("N0")) JD</dd>
            </dl>
        </div>

        <div class="admin-card mb-4">
            <h5 class="text-white fw-bold mb-3">@SharedLocalizer["Admin.Review.Seller"]</h5>
            <p class="text-muted small mb-1">@(Model.Listing.Seller?.Name ?? "—") <span class="badge badge-low ms-1">@(Model.Listing.Seller?.Type ?? "Dealer")</span></p>
            <p class="text-muted small mb-1">@(Model.Listing.Seller?.Email ?? "—")</p>
            <p class="text-muted small mb-0">@(Model.Listing.Seller?.Phone ?? "—") · @(Model.Listing.Seller?.City ?? "—")</p>
        </div>

        <div class="admin-card mb-4">
            <h5 class="text-white fw-bold mb-3">@SharedLocalizer["Admin.Review.Photos"]</h5>
            @if (images.Any())
            {
                <div class="row g-2">
                    @foreach (var img in images)
                    {
                        <div class="col-4 col-md-3">
                            <img src="@img.Url" alt="" class="img-fluid rounded-3" style="height:90px;width:100%;object-fit:cover;" />
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted small mb-0">No photos.</p>
            }
        </div>

        @if (Model.IsUsed)
        {
            <div class="admin-card mb-4">
                <h5 class="text-white fw-bold mb-3">@SharedLocalizer["Admin.Review.UploadsTitle"]</h5>
                @if (Model.InspectionUploads.Any())
                {
                    <div class="row g-3">
                        @foreach (var up in Model.InspectionUploads)
                        {
                            <div class="col-md-4">
                                @if (up.ContentType == "application/pdf")
                                {
                                    <a href="@up.StoredPath" target="_blank" rel="noopener" class="d-flex flex-column align-items-center justify-content-center text-decoration-none border rounded-3 p-3" style="height:120px;">
                                        <i class="fa fa-file-pdf fa-2x text-danger mb-2"></i>
                                        <span class="small text-truncate w-100 text-center text-white">@up.FileName</span>
                                    </a>
                                }
                                else
                                {
                                    <a href="@up.StoredPath" target="_blank" rel="noopener">
                                        <img src="@up.StoredPath" alt="@up.FileName" class="img-fluid rounded-3 border" style="height:120px;width:100%;object-fit:cover;" />
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-warning small mb-0"><i class="fa fa-triangle-exclamation me-1"></i>@SharedLocalizer["Admin.Review.NoUploads"]</p>
                }
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="admin-card mb-4">
            <h5 class="text-white fw-bold mb-3">@SharedLocalizer["Admin.Review.InspectionTitle"]</h5>
            @if (Model.HasInspectionReport)
            {
                <p class="small text-success mb-3"><i class="fa fa-circle-check me-1"></i>@SharedLocalizer["Admin.Review.ReportSaved"]</p>
            }
            else if (Model.IsUsed)
            {
                <p class="small text-warning mb-3"><i class="fa fa-triangle-exclamation me-1"></i>@SharedLocalizer["Admin.Review.ReportRequired"]</p>
            }

            <form method="post" asp-controller="Inspections" asp-action="Edit" asp-route-carId="@Model.InspectionForm.CarId" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input type="hidden" asp-for="InspectionForm.CarId" name="CarId" />
                <input type="hidden" name="returnListingId" value="@Model.Listing.Id" />

                <partial name="_InspectionReportFields" model="Model.InspectionForm" />

                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-primary fw-bold"><i class="fa fa-floppy-disk me-1"></i>@SharedLocalizer["Admin.Review.SaveInspection"]</button>
                </div>
            </form>
        </div>

        <div class="admin-card">
            <h5 class="text-white fw-bold mb-3">@SharedLocalizer["Admin.Review.Decision"]</h5>

            <form asp-action="Approve" method="post" class="mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Listing.Id" />
                <button type="submit" class="btn btn-success fw-bold w-100" @(Model.CanApprove ? "" : "disabled")>
                    <i class="fa fa-check me-1"></i>@SharedLocalizer["Admin.Review.Approve"]
                </button>
                @if (!Model.CanApprove)
                {
                    <small class="text-muted d-block mt-1">@SharedLocalizer["Admin.Review.ApproveBlocked"]</small>
                }
            </form>

            <form asp-action="Reject" method="post" data-confirm="@SharedLocalizer["Admin.Review.RejectConfirm"]">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Listing.Id" />
                <label class="form-label text-muted small fw-bold">@SharedLocalizer["Admin.Review.RejectReasonLabel"]</label>
                <textarea name="reason" class="form-control mb-2" rows="3" required maxlength="1000"
                          placeholder="@SharedLocalizer["Admin.Review.RejectReasonPlaceholder"]">@Model.Listing.RejectionReason</textarea>
                <button type="submit" class="btn btn-outline-danger fw-bold w-100"><i class="fa fa-ban me-1"></i>@SharedLocalizer["Admin.Review.Reject"]</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
