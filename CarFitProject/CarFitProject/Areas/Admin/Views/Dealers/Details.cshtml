@model CarFitProject.Models.Seller

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dealership Details";
}

<style>
    .custom-wide-table th {
        font-weight: 600; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05rem;
        background-color: var(--bg-sidebar) !important; border-bottom: 1px solid var(--border-dim) !important; padding: 14px 12px !important;
    }
    .custom-wide-table td { border-bottom: 1px solid var(--border-dim) !important; padding: 1rem 0.75rem !important; }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 border-bottom border-secondary pb-3" style="border-color: var(--border-dim) !important;">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-outline-dark rounded-circle me-3 hover-lift d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-color: var(--border-color) !important; background: rgba(255,255,255,0.02);">
                            <i class="fa-solid fa-arrow-left text-primary"></i>
                        </a>
                        <div>
                            <span class="badge badge-critical mb-2 text-uppercase tracking-wider">Administration</span>
                            <h1 class="fw-bold text-white mb-0">
                                <i class="fa-solid fa-id-badge me-2 text-primary"></i>@ViewData["Title"]
                            </h1>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="admin-card h-100 p-4 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 80px; height: 80px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-color);">
                    <i class="fa-solid @(Model.Type == "Dealership" ? "fa-building" : "fa-user") fs-1 text-primary"></i>
                </div>
                <h3 class="fw-bold mb-1 text-white">@Model.Name</h3>
                <p class="text-muted fw-bold tracking-wider text-uppercase small mb-3">@Model.Type</p>

                @if (Model.IsApproved)
                {
                    <span class="badge badge-low px-3 py-2 rounded-pill fs-6 mb-3"><i class="fa-solid fa-check-circle me-1"></i> Approved</span>
                }
                else
                {
                    <span class="badge badge-critical px-3 py-2 rounded-pill fs-6 mb-3"><i class="fa-solid fa-clock me-1"></i> Pending</span>
                }

                <hr style="border-color: var(--border-dim) !important;">

                <ul class="list-unstyled text-start mb-0">
                    <li class="mb-3"><strong><i class="fa-solid fa-envelope text-primary me-2 w-20px"></i> Email:</strong> <span class="text-muted ms-2">@(Model.Email ?? "N/A")</span></li>
                    <li class="mb-3"><strong><i class="fa-solid fa-phone text-primary me-2 w-20px"></i> Phone:</strong> <span class="text-muted ms-2">@(Model.Phone ?? "N/A")</span></li>
                    <li class="mb-3"><strong><i class="fa-solid fa-map-location-dot text-primary me-2 w-20px"></i> Location:</strong> <span class="text-muted ms-2">@Model.City @(string.IsNullOrEmpty(Model.Neighborhood) ? "" : $"- {Model.Neighborhood}")</span></li>
                    <li class="mb-3"><strong><i class="fa-solid fa-star text-primary me-2 w-20px"></i> Tier:</strong> <span class="text-muted ms-2">@(Model.Tier ?? "Basic")</span></li>
                </ul>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="admin-card p-0 overflow-hidden h-100">
                <div class="py-3 px-4 border-bottom d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.15); border-color: var(--border-dim) !important;">
                    <h5 class="mb-0 text-white fw-bold"><i class="fa-solid fa-car text-primary me-2"></i> Active Listings (@Model.CarListings.Count)</h5>
                </div>
                <div class="table-responsive">
                    @if (!Model.CarListings.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-car-side fs-1 mb-3 opacity-50"></i>
                            <p>This seller currently has no car listings.</p>
                        </div>
                    }
                    else
                    {
                        <table class="table mb-0 table-hover align-middle w-100 custom-wide-table">
                            <thead>
                                <tr class="text-white">
                                    <th class="ps-4">Vehicle</th>
                                    <th>Status</th>
                                    <th>Price</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var listing in Model.CarListings)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-white fw-bold text-uppercase">@(listing.Car?.Make)</span>
                                                <span class="text-muted">@(listing.Car?.Model)</span>
                                                <span class="badge meta-year-badge" style="background-color: #0b0f19; color: var(--text-muted); border: 1px solid var(--border-dim);">@(listing.Car?.Year)</span>
                                            </div>
                                        </td>
                                        <td>
                                            @if (listing.Status == "Active" || listing.Status == "Available")
                                            {
                                                <span class="badge badge-low">@listing.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-medium">@listing.Status</span>
                                            }
                                        </td>
                                        <td class="text-primary fw-bold font-monospace">@(listing.ListingPrice?.ToString("N0") ?? "N/A") JOD</td>
                                        <td class="text-end pe-4">
                                            <a asp-area="" asp-controller="Inventory" asp-action="Detail" asp-route-id="@listing.Id" target="_blank" class="btn btn-sm btn-outline-info rounded-pill px-3 py-1 hover-lift">
                                                <i class="fa-solid fa-eye me-1"></i> View Car
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
