@model CarFitProject.Models.Seller

@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Dealership / Seller";
}

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 border-bottom border-secondary pb-3" style="border-color: var(--border-dim) !important;">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-outline-dark rounded-circle me-3 hover-lift d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-color: var(--border-color) !important; background: rgba(255,255,255,0.02);">
                            <i class="fa-solid fa-arrow-left text-primary"></i>
                        </a>
                        <div>
                            <span class="badge badge-critical mb-2 text-uppercase tracking-wider">Administration</span>
                            <h1 class="fw-bold text-white mb-0">
                                <i class="fa-solid fa-plus me-2 text-primary"></i>@ViewData["Title"]
                            </h1>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-xl-8">
            <div class="admin-card p-4 p-md-5">
                <form asp-action="Create" method="post">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label text-muted fw-bold text-uppercase tracking-wider small">Seller Name *</label>
                            <input asp-for="Name" class="form-control bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label text-muted fw-bold text-uppercase tracking-wider small">Seller Type *</label>
                            <select asp-for="Type" class="form-select bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" required>
                                <option value="">Choose Type...</option>
                                <option value="Dealership">Dealership</option>
                                <option value="Private">Private User</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label text-muted fw-bold text-uppercase tracking-wider small">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label text-muted fw-bold text-uppercase tracking-wider small">Phone Number</label>
                            <input asp-for="Phone" class="form-control bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="City" class="form-label text-muted fw-bold text-uppercase tracking-wider small">City</label>
                            <input asp-for="City" class="form-control bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Neighborhood" class="form-label text-muted fw-bold text-uppercase tracking-wider small">Neighborhood</label>
                            <input asp-for="Neighborhood" class="form-control bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" />
                            <span asp-validation-for="Neighborhood" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Tier" class="form-label text-muted fw-bold text-uppercase tracking-wider small">Subscription Tier *</label>
                            <select asp-for="Tier" class="form-select bg-dark text-white py-2" style="border: 1px solid var(--border-dim); border-radius: 8px;" required>
                                <option value="">Select Tier...</option>
                                @foreach (var t in (string[])ViewBag.Tiers)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                            <span asp-validation-for="Tier" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-5 border-top pt-4 text-end" style="border-color: var(--border-dim) !important;">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2" style="border-radius: 10px;">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold" style="border-radius: 10px;">
                            <i class="fa-solid fa-check me-1"></i> Create Seller
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
