@model IEnumerable<CarFitProject.Models.Seller>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Dealerships & Sellers";
}

<style>
    .custom-wide-table th {
        font-weight: 600; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05rem;
        background-color: var(--bg-sidebar) !important; border-bottom: 1px solid var(--border-dim) !important; padding: 14px 12px !important;
    }
    .custom-wide-table td { border-bottom: 1px solid var(--border-dim) !important; padding: 1rem 0.75rem !important; }
</style>

<div class="widescreen-wrapper">
    <div class="row mb-4">
        <div class="col-12">
            <div class="admin-card">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 border-bottom border-secondary pb-3" style="border-color: var(--border-dim) !important;">
                    <div>
                        <span class="badge badge-critical mb-2 text-uppercase tracking-wider">Administration</span>
                        <h1 class="fw-bold text-white mb-0">
                            <i class="fa-solid fa-store me-2 text-primary"></i>@ViewData["Title"]
                        </h1>
                    </div>
                    <div class="text-md-end mt-3 mt-md-0">
                        <a asp-action="Create" class="btn btn-outline-dark p-2 hover-lift text-decoration-none" style="border-color: var(--border-color) !important; background: rgba(255,255,255,0.02); border-radius: 10px;">
                            <div class="fw-bold text-white small mb-0"><i class="fa-solid fa-plus me-2 text-primary"></i>Add Seller</div>
                        </a>
                    </div>
                </div>
                <p class="fs-5 text-muted leading-relaxed mb-0 w-100">View and manage all registered dealerships and private sellers.</p>
            </div>
        </div>
    </div>

    <div class="row mb-2">
        <div class="col-12">
            <div class="admin-card p-0 overflow-hidden shadow-sm">
                <div class="py-3 px-4 border-bottom d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.15); border-color: var(--border-dim) !important;">
                    <h5 class="mb-0 text-white fw-bold"><i class="fa-solid fa-users me-2 text-primary"></i>All Sellers</h5>
                </div>
                <div class="table-responsive">
                    <table class="table mb-0 table-hover align-middle w-100 custom-wide-table">
                        <thead>
                            <tr class="text-white">
                                <th class="ps-4">Name</th>
                                <th>Type</th>
                                <th>City</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">No sellers found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var seller in Model)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-white">@seller.Name</td>
                                        <td>
                                            @if (seller.Type == "Dealership")
                                            {
                                                <span class="badge badge-low"><i class="fa-solid fa-building me-1"></i> Dealership</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-medium"><i class="fa-solid fa-user me-1"></i> Private</span>
                                            }
                                        </td>
                                        <td class="text-muted">@(string.IsNullOrWhiteSpace(seller.City) ? "-" : seller.City)</td>
                                        <td>
                                            @if (seller.IsApproved)
                                            {
                                                <span class="badge badge-low"><i class="fa-solid fa-check me-1"></i> Approved</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-critical"><i class="fa-solid fa-clock me-1"></i> Pending</span>
                                            }
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a asp-action="Details" asp-route-id="@seller.Id" class="btn btn-sm btn-outline-info rounded-pill px-3 py-1">
                                                    <i class="fa-solid fa-eye"></i> Details
                                                </a>
                                                <form asp-action="Delete" asp-route-id="@seller.Id" method="post" data-confirm="Are you sure you want to completely delete @seller.Name? This action cannot be undone.">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1">
                                                        <i class="fa-solid fa-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
