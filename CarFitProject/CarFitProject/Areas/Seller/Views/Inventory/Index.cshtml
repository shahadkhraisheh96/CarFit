@model CarFitProject.Helpers.PaginatedList<CarFitProject.Models.CarListing>
@{
    ViewData["Title"] = SharedLocalizer["Seller.Inventory.Title"].Value;
}

<div class="container py-4">
    <div class="page-hero mb-4">
        <div class="row align-items-center g-3">
            <div class="col-md-8">
                <span class="eyebrow"><i class="fa-solid fa-warehouse me-1"></i> My Lot</span>
                <h1 class="mb-2">@SharedLocalizer["Seller.Inventory.Title"]</h1>
                <p class="lead mb-0">@SharedLocalizer["Seller.Inventory.Subtitle"]</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-action="Form" class="btn btn-primary fw-bold">
                    <i class="fa fa-plus me-2"></i>@SharedLocalizer["Seller.Inventory.Add"]
                </a>
            </div>
        </div>
    </div>

    
    

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa fa-car-side"></i></div>
            <h3>No vehicles listed yet</h3>
            <p>Add your first vehicle to start showing up in buyer searches.</p>
            <a asp-action="Form" class="btn btn-primary fw-bold">Add your first listing</a>
        </div>
    }
    else
    {
        <div class="dash-shell p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="compare-table mb-0">
                    <thead>
                        <tr>
                            <th>Vehicle</th>
                            <th>Year</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@(item.Car?.Make) @(item.Car?.Model)</div>
                                    <div class="text-muted small">@(item.Car?.Trim)</div>
                                </td>
                                <td>@(item.Car?.Year)</td>
                                <td class="fw-bold">@(item.ListingPrice?.ToString("N0")) <small class="text-muted">JD</small></td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case CarFitProject.Models.ListingStatus.Approved:
                                            <span class="chip chip-success"><i class="fa fa-circle-check"></i>@SharedLocalizer["Listing.Status.Approved"]</span>
                                            break;
                                        case CarFitProject.Models.ListingStatus.PendingInspectionReview:
                                            <span class="chip chip-warning"><i class="fa fa-clock"></i>@SharedLocalizer["Listing.Status.PendingInspectionReview"]</span>
                                            break;
                                        case CarFitProject.Models.ListingStatus.Rejected:
                                            <span class="chip chip-danger" data-bs-toggle="tooltip" title="@item.RejectionReason"><i class="fa fa-circle-xmark"></i>@SharedLocalizer["Listing.Status.Rejected"]</span>
                                            break;
                                        case CarFitProject.Models.ListingStatus.Sold:
                                            <span class="chip"><i class="fa fa-tag"></i>@SharedLocalizer["Listing.Status.Sold"]</span>
                                            break;
                                        case CarFitProject.Models.ListingStatus.Draft:
                                            <span class="chip"><i class="fa fa-pen"></i>@SharedLocalizer["Listing.Status.Draft"]</span>
                                            break;
                                        default:
                                            <span class="chip">@item.Status</span>
                                            break;
                                    }
                                    @if (item.Status == CarFitProject.Models.ListingStatus.Rejected && !string.IsNullOrWhiteSpace(item.RejectionReason))
                                    {
                                        <div class="text-danger small mt-1"><strong>@SharedLocalizer["Listing.Status.RejectionReasonLabel"]:</strong> @item.RejectionReason</div>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                        <a asp-action="Form" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold">
                                            <i class="fa fa-pen me-1"></i>Edit
                                        </a>
                                        @if (item.CarId.HasValue)
                                        {
                                            <a asp-controller="Inspections" asp-action="Edit" asp-route-carId="@item.CarId" class="btn btn-sm btn-outline-info fw-bold">
                                                <i class="fa fa-clipboard-check me-1"></i>Inspection
                                            </a>
                                        }
                                        @if (item.Status == CarFitProject.Models.ListingStatus.Approved)
                                        {
                                            <form asp-action="Deactivate" method="post" class="m-0"
                                                  data-confirm="Mark this listing as sold?">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning fw-bold">
                                                    <i class="fa fa-ban me-1"></i>Mark sold
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" method="post" class="m-0"
                                              data-confirm="Delete this listing permanently?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                                                <i class="fa fa-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <partial name="_Pager" model="@(new CarFitProject.ViewModel.PagerViewModel { Page = Model.PageIndex, TotalPages = Model.TotalPages, Action = "Index" })" />
    }
</div>
