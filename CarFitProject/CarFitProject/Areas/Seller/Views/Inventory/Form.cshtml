        (function () {
            var currentMake = '@Html.Raw(Model?.Make ?? "")';
            var currentModel = '@Html.Raw(Model?.Model ?? "")';
            
            var makeSelect = document.getElementById('makeSelect');
            var modelSelect = document.getElementById('modelSelect');
            
            if (makeSelect && modelSelect) {
                // Populate makes
                Object.keys(carData).sort().forEach(function(make) {
                    var option = document.createElement("option");
                    option.value = make;
                    option.text = make;
                    makeSelect.appendChild(option);
                });
                
                // Set initial make
                if (currentMake) {
                    makeSelect.value = currentMake;
                }
                
                // Function to populate models
                function populateModels(make) {
                    modelSelect.innerHTML = '<option value="">Select Model</option>';
                    if (make && carData[make]) {
                        carData[make].forEach(function(model) {
                            var option = document.createElement("option");
                            option.value = model;
                            option.text = model;
                            modelSelect.appendChild(option);
                        });
                    }
                }
                
                // Listen for make changes
                makeSelect.addEventListener('change', function() {
                    populateModels(this.value);
                });
                
                // Initial population of models if make is selected
                if (makeSelect.value) {
                    populateModels(makeSelect.value);
                    if (currentModel) {
                        modelSelect.value = currentModel;
                    }
                }
            }
        })();

        // Show the inspection-evidence section only for Used cars; New cars hide it
        // and clear any chosen files so they aren't posted. Server-side still enforces this.
        (function () {
            var sel = document.getElementById('conditionSelect');
            var section = document.getElementById('inspectionSection');
            var input = document.getElementById('inspectionFiles');
            
            var uploadSection = document.getElementById('uploadSection');
            var radios = document.querySelectorAll('input[name="RequestInspection"]');

            if (!sel || !section) return;

            function sync() {
                var isUsed = sel.value === 'Used';
                section.style.display = isUsed ? '' : 'none';
                if (!isUsed && input) input.value = '';

                if (isUsed && uploadSection) {
                    var isBook = document.getElementById('choiceBook').checked;
                    uploadSection.style.display = isBook ? 'none' : '';
                    if (isBook && input) input.value = '';
                }
            }
            sel.addEventListener('change', sync);
            radios.forEach(r => r.addEventListener('change', sync));
            sync();
        })();

        // Wizard navigation logic
        (function() {
            var currentStep = 1;
            var totalSteps = 4;
            var stepNames = ['Basics', 'Specs', 'Features', 'Listing'];
            var form = $('#wizardForm');

            function showStep(step) {
                $('.wizard-step-content').addClass('d-none');
                $('#step' + step).removeClass('d-none');

                // Update desktop stepper
                $('.wizard-step').removeClass('is-active is-done');
                $('.wizard-step').each(function() {
                    var s = parseInt($(this).data('step'));
                    if (s < step) {
                        $(this).addClass('is-done');
                        $(this).find('.step-bullet').html('<i class="fa-solid fa-check"></i>');
                    } else if (s === step) {
                        $(this).addClass('is-active');
                        $(this).find('.step-bullet').text(s);
                    } else {
                        $(this).find('.step-bullet').text(s);
                    }
                });

                // Update mobile stepper
                $('#mobileStepText').text('Step ' + step + ' of ' + totalSteps);
                $('#mobileStepTitle').text(stepNames[step - 1]);
                $('#mobileProgressBar').css('width', Math.round(100 * step / totalSteps) + '%');
            }

            $('.next-step').click(function() {
                var step = parseInt($(this).data('current'));
                
                // Trigger unobtrusive validation
                if (form.length && $.validator && $.validator.unobtrusive) {
                    form.validate();
                }

                // Validate only the inputs in the current step
                var isValid = true;
                $('#step' + step).find('input, select, textarea').each(function() {
                    // Check if it's required by data-val-required or HTML5 required
                    if ($(this).attr('data-val-required') || $(this).prop('required')) {
                        if (!form.validate().element(this)) {
                            isValid = false;
                        }
                    }
                });

                if (isValid) {
                    currentStep = step + 1;
                    showStep(currentStep);
                    window.scrollTo(0, 0);
                }
            });

            $('.prev-step').click(function() {
                var step = parseInt($(this).data('current'));
                currentStep = step - 1;
                showStep(currentStep);
                window.scrollTo(0, 0);
            });
            
            showStep(1);
        })();
    </script>
}
