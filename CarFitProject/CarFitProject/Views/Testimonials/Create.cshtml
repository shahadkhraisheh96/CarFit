@model CarFitProject.ViewModel.TestimonialFormViewModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Your Review" : "Leave a Review";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Accessible star-rating input: real radios, visually rendered as stars.
       Reverse row direction so the CSS sibling selector can light up the chosen
       star and everything to its left on hover/check. */
    .star-rating { display: inline-flex; flex-direction: row-reverse; gap: .25rem; font-size: 2rem; }
    .star-rating input { position: absolute; opacity: 0; width: 0; height: 0; }
    .star-rating label { color: #d0d5dd; cursor: pointer; line-height: 1; transition: color .15s ease; }
    .star-rating label:hover,
    .star-rating label:hover ~ label,
    .star-rating input:checked ~ label { color: #f59e0b; }
</style>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="text-center mb-4">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">SHARE YOUR EXPERIENCE</span>
            <h1 class="fw-bold text-dark">@(Model.IsEdit ? "Update your review" : "Tell us about CarFit")</h1>
            <p class="text-muted">Your review helps other drivers trust the platform. Approved reviews appear on the home page.</p>
        </div>

        

        @if (Model.IsEdit)
        {
            <div class="alert alert-info d-flex align-items-center gap-2" role="alert">
                <i class="fa-solid fa-circle-info"></i>
                <div>You already have a review. Saving your changes will send it back for admin approval before it appears publicly again.</div>
            </div>
        }

        <div class="glass-card p-4 p-md-5">
            <form asp-controller="Testimonials" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IsEdit" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="ReviewerName" class="form-label fw-semibold text-dark"></label>
                    <input asp-for="ReviewerName" class="form-control form-control-lg" placeholder="The name to show on your review" />
                    <span asp-validation-for="ReviewerName" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold text-dark d-block">@Html.DisplayNameFor(m => m.Rating)</label>
                    <div class="star-rating" role="radiogroup" aria-label="Star rating">
                        @* Rendered reversed (5 → 1) so the CSS hover/checked rule can fill leftward. *@
                        @for (var star = 5; star >= 1; star--)
                        {
                            var id = $"rating-{star}";
                            <input type="radio" asp-for="Rating" value="@star" id="@id" />
                            <label for="@id" title="@star star@(star > 1 ? "s" : "")"><i class="fa-solid fa-star"></i></label>
                        }
                    </div>
                    <div><span asp-validation-for="Rating" class="text-danger small"></span></div>
                </div>

                <div class="mb-4">
                    <label asp-for="ReviewText" class="form-label fw-semibold text-dark"></label>
                    <textarea asp-for="ReviewText" class="form-control" rows="5" maxlength="1000" placeholder="What did you like about using CarFit?"></textarea>
                    <span asp-validation-for="ReviewText" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg px-4 fw-bold">
                        <i class="fa-solid fa-paper-plane me-2"></i>@(Model.IsEdit ? "Save Changes" : "Submit Review")
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
