@model List<CarFitProject.Models.CarListing>
@{
    ViewData["Title"] = L["Home.Hero.Headline"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="position-relative overflow-hidden mb-5 py-5" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--dark) 100%); min-height: 550px; display: flex; align-items: center;">
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background-image: url('/img/carousel-bg-1.jpg'); background-position: center; background-size: cover; mix-blend-mode: overlay; pointer-events: none;"></div>
    <div class="container position-relative py-4" style="z-index: 2;">
        <div class="row align-items-center">
            <div class="col-lg-7 text-start pt-3">
                <span class="badge bg-primary bg-opacity-20 text-white border border-primary px-3 py-2 rounded-pill fw-bold mb-3">CarFit Smart Match Engine </span>
                <h1 class="display-3 text-white mb-4 fw-black">@L["Home.Hero.Headline"]</h1>
                <p class="fs-5 text-white-50 mb-5 leading-relaxed" style="max-width: 600px;">
                    @L["Home.Hero.Tagline"]
                </p>
                <div class="d-flex flex-wrap gap-3 position-relative" style="z-index: 10;">
                    <a href="/Buyer/Questionnaire/Start" class="btn btn-primary btn-lg px-5 py-3"><i class="fa-solid fa-clipboard-question me-2"></i>@L["Home.Hero.CTA.Questionnaire"]</a>

                    <a href="/Inventory/Search" class="btn btn-outline-primary btn-lg px-4 py-3 text-white"><i class="fa-solid fa-car-side me-2"></i>@L["Home.Hero.CTA.Showroom"]</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="glass-card p-5 text-white shadow-lg text-center rounded-4 border-0" style="background: linear-gradient(135deg, rgba(26,26,46,0.9) 0%, rgba(216,19,36,0.9) 100%); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.15) !important;">
                    <i class="fa-solid fa-award text-warning fs-1 mb-3"></i>
                    <h3 class="text-white fw-bold">@L["Home.Hero.Verified"]</h3>
                    <p class="text-white-50 small mb-0">Every vehicle listed on CarFit goes through a comprehensive multi-point chassis and sensor scanner check before recommendation.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">CORE VALUE PROPOSITION</span>
            <h1 class="fw-bold text-dark">@L["Home.Value.SectionTitle"]</h1>
            <p class="text-muted">@L["Home.Value.SectionSubtitle"]</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="glass-card h-100 hover-lift text-start p-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 d-inline-block mb-4">
                        <i class="fa-solid fa-user-check fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-3 text-dark">@L["Home.Value.Profile.Title"]</h5>
                    <p class="text-muted small mb-0">@L["Home.Value.Profile.Body"]</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="glass-card h-100 hover-lift text-white text-start p-4" style="background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-light) 100%);">
                    <div class="bg-white bg-opacity-10 text-white rounded-3 p-3 d-inline-block mb-4">
                        <i class="fa-solid fa-file-invoice fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-3 text-white">@L["Home.Value.WhiteCard.Title"]</h5>
                    <p class="text-white-50 small mb-0">@L["Home.Value.WhiteCard.Body"]</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="glass-card h-100 hover-lift text-start p-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 d-inline-block mb-4">
                        <i class="fa-solid fa-shield-halved fs-3"></i>
                    </div>
                    <h5 class="fw-bold mb-3 text-dark">@L["Home.Value.Protection.Title"]</h5>
                    <p class="text-muted small mb-0">@L["Home.Value.Protection.Body"]</p>
                </div>
            </div>
        </div>
    </div>
</div>
@{
    var makes = ViewBag.Makes as List<CarFitProject.ViewModel.MakeSummaryViewModel> ?? new List<CarFitProject.ViewModel.MakeSummaryViewModel>();
}
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">@L["Home.Makes.Badge"]</span>
            <h1 class="fw-bold text-dark">@L["Home.Makes.SectionTitle"]</h1>
            <p class="text-muted">@L["Home.Makes.SectionSubtitle"]</p>
        </div>

        @if (!makes.Any())
        {
            <div class="col-12 text-center py-4 text-muted">
                <i class="fa-solid fa-car-side fs-2 mb-2 opacity-25"></i>
                <p class="small mb-0">@L["Home.Makes.Empty"]</p>
            </div>
        }
        else
        {
            <div class="makes-marquee-container">
                <div class="makes-marquee-track">
                    @for (int i = 0; i < 2; i++)
                    {
                        <div class="marquee-content" aria-hidden="@(i == 1 ? "true" : "false")">
                            @for (int j = 0; j < 3; j++)
                            {
                                @foreach (var m in makes)
                                {
                                    var initial = string.IsNullOrWhiteSpace(m.Name) ? "?" : m.Name.Trim()[..1].ToUpper();
                                    var hasLogo = !string.IsNullOrEmpty(m.LogoUrl);
                                    
                                    <a asp-area="" asp-controller="Inventory" asp-action="Search" asp-route-Make="@m.Name"
                                       class="make-marquee-card d-flex align-items-center gap-3 p-3 text-decoration-none"
                                       aria-label="@m.Name — @L["Home.Makes.CarsAvailable", m.CarCount]">
                                        
                                        <div class="make-logo-wrapper flex-shrink-0 d-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm" style="width: 56px; height: 56px; padding: 10px;">
                                            @if (hasLogo)
                                            {
                                                <img src="@m.LogoUrl" alt="@m.Name" class="make-logo-img w-100 h-100" style="object-fit: contain;"
                                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                <div class="make-logo-fallback text-primary fw-black align-items-center justify-content-center w-100 h-100" style="display: none; font-size: 1.25rem;">
                                                    @initial
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="make-logo-fallback text-primary fw-black d-flex align-items-center justify-content-center w-100 h-100" style="font-size: 1.25rem;">
                                                    @initial
                                                </div>
                                            }
                                        </div>
                                        <div class="make-info text-start flex-grow-1 overflow-hidden">
                                            <h6 class="fw-bold text-white mb-0 text-truncate">@m.Name</h6>
                                            <span class="small text-white-50">@L["Home.Makes.CarsAvailable", m.CarCount]</span>
                                        </div>
                                        <div class="make-arrow text-white opacity-50 ms-2 transition-all">
                                            <i class="fa-solid fa-chevron-right small"></i>
                                        </div>
                                    </a>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
<div class="container-xxl py-5 bg-light rounded-4 my-5 px-4" style="background-color: rgba(0,0,0,0.02) !important;">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end mb-5">
            <div>
                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20 px-3 py-2 rounded-pill fw-bold mb-2">LIVE PLATFORM BUFFER</span>
                <h1 class="fw-bold text-dark mb-0">Recently Processed Additions</h1>
                <p class="text-muted mb-0 mt-1">Verified vehicle lots ready for direct inspection screening.</p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-area="" asp-controller="Inventory" asp-action="Search" class="btn btn-outline-dark fw-bold px-4 py-2">
                    View Complete Catalog <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>

        <div class="row g-4">
            @if (Model == null || !Model.Any())
            {
                <div class="col-12 text-center py-4 text-muted">
                    <i class="fa-solid fa-folder-open fs-2 mb-2 opacity-25"></i>
                    <p class="small mb-0">Showroom database pipeline caching elements. Check back shortly!</p>
                </div>
            }
            else
            {
                foreach (var vehicle in Model.Take(3)) // Take the latest 3 elements for the landing spotlight snippet
                {
                    <div class="col-12 col-md-4">
                        @{
                            var primary = vehicle.Car?.CarImages?.OrderByDescending(i => i.IsPrimary).ThenBy(i => i.SortOrder).FirstOrDefault();
                        }
                        <div class="bg-white shadow-sm rounded-4 overflow-hidden h-100 d-flex flex-column hover-lift position-relative">
                            @if (vehicle.Car?.InspectionReport?.CarseerAttached == true)
                            {
                                <span class="badge bg-info text-white position-absolute top-0 end-0 m-2" style="z-index: 2;"><i class="fa fa-shield-halved me-1"></i>CarSeer</span>
                            }
                            <a asp-action="Detail" asp-controller="Inventory" asp-route-id="@vehicle.Id" class="text-decoration-none text-dark">
                                <div style="height: 180px; background:#f1f1f1;">
                                    @if (primary != null)
                                    {
                                        <img src="@primary.Url" alt="@vehicle.Car?.Make @vehicle.Car?.Model" class="w-100 h-100" style="object-fit: cover;" />
                                    }
                                </div>
                                <div class="p-3">
                                    <h5 class="fw-bold mb-1">@vehicle.Car?.Make @vehicle.Car?.Model</h5>
                                    <div class="text-muted small mb-2">@vehicle.Car?.Year · @vehicle.Car?.Transmission · @vehicle.Car?.Type</div>
                                    <div class="fw-bold text-danger fs-5">@(vehicle.ListingPrice?.ToString("N0")) JD</div>
                                </div>
                            </a>
                            <div class="p-3 border-top d-flex gap-2 mt-auto">
                                <a asp-action="Detail" asp-controller="Inventory" asp-route-id="@vehicle.Id" class="btn btn-sm btn-outline-primary fw-bold w-100">
                                    View Car Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6" style="min-height: 400px;">
                <div class="position-relative h-100 overflow-hidden rounded-4 shadow-lg hover-lift">
                    <img class="img-fluid w-100 h-100" src="/img/about.jpg" style="object-fit: cover; min-height: 400px;" alt="Chassis Verification Terminal">
                </div>
            </div>
            <div class="col-lg-6">
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">INSPECTION EVALUATION MATRIX</span>
                <h1 class="fw-bold text-dark mb-4">Understanding your "ورقة الفحص" Mechanics Without Jargon</h1>
                <p class="text-muted mb-4">Every car condition is rated using standard Jordanian market scale metrics. Our system translates raw garage remarks into plain-language warnings so you know exactly what you are paying for.</p>
                
                <div class="d-flex flex-column gap-3 mb-4">
                    <div class="d-flex align-items-center bg-white p-3 rounded-3 shadow-sm border-start border-5 border-success">
                        <i class="fa-solid fa-circle-check text-success fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-1 fw-bold text-dark">جيد (Good) / قصعة شنكل (Loading Dent)</h6>
                            <p class="mb-0 text-muted small">Structural integrity is sound. Zero to negligible impact on vehicle safety parameters or market valuation.</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center bg-white p-3 rounded-3 shadow-sm border-start border-5 border-warning">
                        <i class="fa-solid fa-triangle-exclamation text-warning fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-1 fw-bold text-dark">دقة / ضربة على الرأس (Chassis Head Hits)</h6>
                            <p class="mb-0 text-muted small">Minor front/rear impact with 1cm to 5cm deviations. Minor market value adjustments applied.</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center bg-white p-3 rounded-3 shadow-sm border-start border-5 border-danger">
                        <i class="fa-solid fa-skull-crossbones text-danger fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-1 fw-bold text-dark">مضروب ومشغول / شاصي مقصوص ومغير (Risky Flags)</h6>
                            <p class="mb-0 text-muted small">Heavy structural damage or cut frame modifications. Flagged immediately by our AI scoring matrix as dangerous.</p>
                        </div>
                    </div>
                </div>
                <a asp-controller="Inspection" asp-action="Index" class="btn btn-primary py-3 px-5 fw-bold"><i class="fa-solid fa-magnifying-glass me-2"></i>Explore Complete Interactive Glossary</a>
            </div>
        </div>
    </div>
</div>
<div class="container-fluid fact py-5 my-5 text-white">
    <div class="container">
        <div class="row g-4 justify-content-center text-center">
            <div class="col-6 col-md-3">
                <i class="fa-solid fa-chart-pie fs-1 mb-3 text-primary-gradient"></i>
                <h2 class="text-white mb-2 fw-bold">50% / 30% / 20%</h2>
                <p class="text-white-50 mb-0 small">Profile + Inspection + Budget Weights</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="fa-solid fa-language fs-1 mb-3 text-primary-gradient"></i>
                <h2 class="text-white mb-2 fw-bold">Bilingual</h2>
                <p class="text-white-50 mb-0 small">English & Arabic Layouts</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="fa-solid fa-bolt fs-1 mb-3 text-primary-gradient"></i>
                <h2 class="text-white mb-2 fw-bold">&lt; 2 Seconds</h2>
                <p class="text-white-50 mb-0 small">Algorithmic Match Engine Speed</p>
            </div>
            <div class="col-6 col-md-3">
                <i class="fa-solid fa-shield-halved fs-1 mb-3 text-primary-gradient"></i>
                <h2 class="text-white mb-2 fw-bold">BCrypt / CSRF</h2>
                <p class="text-white-50 mb-0 small">Production-Grade Security Standards</p>
            </div>
        </div>
    </div>
</div>
@{
    var testimonials = ViewBag.Testimonials as List<CarFitProject.Models.Testimonial> ?? new List<CarFitProject.Models.Testimonial>();

}
@* Testimonials carousel: always rendered, even with no approved reviews yet. *@
<div class="container-xxl py-5">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end mb-5">
            <div>
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">WHAT DRIVERS SAY</span>
                <h1 class="fw-bold text-dark mb-0">Trusted by the CarFit Community</h1>
                <p class="text-muted mb-0 mt-1">Real reviews from buyers and dealers using the platform.</p>
            </div>
            @if (testimonials.Any())
            {
                <div class="mt-3 mt-md-0">
                    @await Component.InvokeAsync("ReviewButton", new { cssClass = "btn btn-outline-dark fw-bold px-4 py-2", iconClass = "fa-solid fa-pen" })
                </div>
            }
        </div>

        @if (testimonials.Any())
        {
            <div class="testimonials-marquee-container mt-4">
                <div class="testimonials-marquee-track">
                    @for (int i = 0; i < 2; i++)
                    {
                        <div class="testimonials-marquee-content" aria-hidden="@(i == 1 ? "true" : "false")">
                            @for (int j = 0; j < 3; j++)
                            {
                                @foreach (var review in testimonials)
                                {
                                    <div class="testimonial-card d-flex flex-column hover-lift">
                                        <div class="d-flex align-items-center justify-content-between mb-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="testimonial-avatar shadow-sm">
                                                    @(string.IsNullOrWhiteSpace(review.ReviewerName) ? "?" : review.ReviewerName.Trim()[..1].ToUpper())
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold text-dark fs-5">@review.ReviewerName</h6>
                                                    <small class="text-muted">@review.CreatedDate.ToString("MMM yyyy")</small>
                                                </div>
                                            </div>
                                            <i class="fa-solid fa-quote-right fs-1 text-primary opacity-10"></i>
                                        </div>
                                        <div class="testimonial-stars mb-3 fs-5" aria-label="@review.Rating out of 5 stars">
                                            @for (var star = 1; star <= 5; star++)
                                            {
                                                <i class="fa-solid fa-star @(star <= review.Rating ? "" : "empty")"></i>
                                            }
                                        </div>
                                        <p class="text-muted mb-0 flex-grow-1 fs-6">@review.ReviewText</p>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            @* Empty state: Styled like the hero verification card *@
            <div class="rounded-4 overflow-hidden position-relative mx-auto" style="max-width: 700px; background: linear-gradient(135deg, var(--secondary) 0%, var(--primary) 100%);">
                <div class="glass-card bg-opacity-10 border-white border-opacity-25 p-5 text-white shadow-lg text-center" style="backdrop-filter: blur(20px);">
                    <i class="fa-solid fa-comment-dots text-white opacity-75 fs-1 mb-3"></i>
                    <h3 class="text-white fw-bold">Be the first to review us</h3>
                    <p class="text-white-50 small mb-4">No reviews yet — share your experience with CarFit and help other drivers.</p>
                    @await Component.InvokeAsync("ReviewButton", new { cssClass = "btn btn-primary btn-lg fw-bold px-5", iconClass = "fa-solid fa-pen" })
                </div>
            </div>
        }
    </div>
</div>
<div class="container-xxl py-5" id="contact-panel-section">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill fw-bold mb-2">SYSTEM ACCESS & INQUIRIES</span>
            <h1 class="fw-bold text-dark">CarFit Support & Connection Gateway</h1>
            <p class="text-muted">Reach out to our automotive validation coordinators in Amman.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-4 col-md-6">
                <div class="glass-card text-center p-4 h-100 border-bottom border-4 border-danger">
                    <i class="fa-solid fa-location-dot fs-2 text-danger mb-3"></i>
                    <h5 class="fw-bold text-dark">Target Market Hub</h5>
                    <p class="mb-1 text-muted">Amman, Jordan</p>
                    <small class="text-secondary d-block mt-1">Serving inspection garages nationwide</small>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="glass-card text-center p-4 h-100 border-bottom border-4 border-danger">
                    <i class="fa-solid fa-envelope-open-text fs-2 text-danger mb-3"></i>
                    <h5 class="fw-bold text-dark">Electronic Support</h5>
                    <p class="mb-1 text-danger fw-medium">support@carfit.jo</p>
                    <small class="text-secondary d-block mt-1">Replies within 24 business hours</small>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="glass-card text-center p-4 h-100 border-bottom border-4 border-danger">
                    <i class="fa-brands fa-whatsapp fs-2 text-danger mb-3"></i>
                    <h5 class="fw-bold text-dark">Direct Listings</h5>
                    <p class="mb-1 text-muted">WhatsApp Integration</p>
                    <small class="text-secondary d-block mt-1">Seller routing system access</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        /* Makes Marquee */
        .makes-marquee-container {
            position: relative;
            width: 100%;
            overflow: hidden;
            padding: 1rem 0;
            -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
            mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        }
        .makes-marquee-track {
            display: flex;
            width: max-content;
        }
        .marquee-content {
            display: flex;
            gap: 1.5rem;
            padding-right: 1.5rem;
            animation: scrollMakes 35s linear infinite;
        }
        .makes-marquee-container:hover .marquee-content {
            animation-play-state: paused;
        }
        @@keyframes scrollMakes {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        .make-marquee-card {
            min-width: 260px;
            background: linear-gradient(135deg, var(--primary, #D81324), #b91c1c);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 1rem;
            box-shadow: 0 4px 15px rgba(216, 19, 36, 0.15);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .make-marquee-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 25px rgba(216, 19, 36, 0.3);
            border-color: rgba(255, 255, 255, 0.3);
        }
        .make-marquee-card:hover .make-arrow {
            transform: translateX(4px);
            opacity: 1 !important;
        }
        .make-arrow {
            transition: all 0.3s ease;
        }

        /* Testimonials Marquee */
        .testimonials-marquee-container {
            position: relative;
            width: 100%;
            overflow: hidden;
            padding: 2rem 0;
            -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
            mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
        }
        .testimonials-marquee-track {
            display: flex;
            width: max-content;
        }
        .testimonials-marquee-content {
            display: flex;
            gap: 2rem;
            padding-right: 2rem;
            animation: scrollTestimonials 50s linear infinite;
        }
        .testimonials-marquee-container:hover .testimonials-marquee-content {
            animation-play-state: paused;
        }
        @@keyframes scrollTestimonials {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        .testimonial-card {
            min-width: 400px;
            max-width: 400px;
            min-height: 300px;
            background: #ffffff;
            border: 1px solid rgba(0,0,0,0.06);
            border-radius: 1.5rem;
            padding: 2rem;
            box-shadow: 0 8px 25px rgba(0,0,0,0.03);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .testimonial-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border-color: rgba(0, 0, 0, 0.12);
        }
        .testimonial-avatar {
            width: 60px; height: 60px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
            color: #fff; font-weight: 700; background: linear-gradient(135deg, var(--primary, #D81324), #7f1d1d);
        }
