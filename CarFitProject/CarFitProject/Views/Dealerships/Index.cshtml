@model List<CarFitProject.ViewModel.DealershipViewModel>
@{
    ViewData["Title"] = "Dealerships";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark mb-3">Certified Dealerships & Sellers</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            Browse our network of trusted dealerships and private sellers. Every vehicle listed undergoes a multi-point chassis and sensor check.
        </p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center shadow-sm rounded-3 py-4" role="alert">
            <i class="fa fa-info-circle fs-3 mb-2 d-block text-info"></i>
            <strong>No active sellers found.</strong> Check back later as inventory updates daily!
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var seller in Model)
            {
                var isDealership = string.Equals(seller.Type, "Dealership", StringComparison.OrdinalIgnoreCase);
                
                <div class="col-md-6 col-lg-4">
                    <a asp-controller="Inventory" asp-action="Search" asp-route-SellerId="@seller.Id" class="text-decoration-none">
                        <div class="card h-100 border-0 rounded-4 shadow-sm" style="transition: transform 0.2s, box-shadow 0.2s;" 
                             onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 40px rgba(13,13,22,0.14)';" 
                             onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(13,13,22,0.06)';">
                            <div class="card-body p-4 position-relative">
                                
                                <!-- Badge -->
                                <div class="position-absolute top-0 end-0 mt-3 me-3">
                                    @if (isDealership)
                                    {
                                        <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-building me-1"></i> Dealership</span>
                                    }
                                    else
                                    {
                                        <span class="badge px-3 py-2 rounded-pill shadow-sm text-white" style="background-color: var(--secondary);"><i class="fa-solid fa-user me-1"></i> Private Seller</span>
                                    }
                                </div>
                                
                                <!-- Icon / Avatar placeholder -->
                                <div class="mb-3">
                                    <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle" style="width: 60px; height: 60px;">
                                        <i class="fa-solid @(isDealership ? "fa-store" : "fa-user-tie") fs-3"></i>
                                    </div>
                                </div>
                                
                                <h4 class="card-title fw-bold text-dark mb-1">@seller.Name</h4>
                                
                                <div class="d-flex align-items-center text-muted small mb-3">
                                    <i class="fa-solid fa-location-dot text-danger me-2"></i>
                                    @(string.IsNullOrWhiteSpace(seller.City) ? "Location unlisted" : seller.City)
                                </div>
                                
                                <hr class="my-3 opacity-10">
                                
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <span class="text-secondary fw-medium">
                                        <i class="fa-solid fa-car text-primary me-2"></i> @seller.ActiveListingsCount Active Car@(seller.ActiveListingsCount == 1 ? "" : "s")
                                    </span>
                                    <span class="btn btn-sm btn-outline-primary rounded-pill px-3">View Inventory <i class="fa-solid fa-arrow-right ms-1"></i></span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
