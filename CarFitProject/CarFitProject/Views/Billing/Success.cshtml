@{
    ViewData["Title"] = SharedLocalizer["Billing.Success.Title"].Value;
}
<div class="container py-5 text-center" style="max-width:560px;">
    <div class="form-section-card" style="max-width:none;">
        <i class="fa fa-circle-check text-success" style="font-size:3rem;"></i>
        <h1 class="mt-3">@SharedLocalizer["Billing.Success.Title"]</h1>
        <p class="lead text-muted">@SharedLocalizer["Billing.Success.Body"]</p>
        <a asp-action="Manage" class="btn btn-primary mt-2">@SharedLocalizer["Billing.ManageLink"]</a>
    </div>
</div>
