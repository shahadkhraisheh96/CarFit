@using CarFitProject.ViewModel
@using CarFitProject.Models.Subscriptions
@model ManageBillingViewModel
@{
    ViewData["Title"] = SharedLocalizer["Billing.Manage.Title"].Value;

    string StatusChip(SubscriptionStatus s) => s switch
    {
        SubscriptionStatus.Active => "chip-success",
        SubscriptionStatus.Trial => "chip-info",
        SubscriptionStatus.PastDue => "chip-warning",
        _ => "chip-secondary"
    };
}

<div class="container py-5">
    
    

    <div class="page-hero mb-4">
        <span class="eyebrow"><i class="fa fa-wallet me-1"></i> @SharedLocalizer["Billing.Eyebrow"]</span>
        <h1 class="mb-1">@SharedLocalizer["Billing.Manage.Title"]</h1>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="form-section-card h-100" style="max-width:none;">
                <h3 class="fw-bold mb-3">@SharedLocalizer["Billing.Manage.CurrentPlan"]</h3>
                @if (Model.Current != null)
                {
                    <p class="mb-2">
                        <strong>@Model.Current.Plan?.Name</strong>
                        <span class="chip @StatusChip(Model.Current.Status) ms-2">@SharedLocalizer[$"Billing.Status.{Model.Current.Status}"]</span>
                    </p>
                    @if (Model.Current.Plan != null && Model.Current.Plan.BillingInterval != PlanBillingInterval.OneTime)
                    {
                        <p class="text-muted mb-1">
                            @Model.Current.Plan.AmountJod.ToString("0.###") @SharedLocalizer["Common.JOD"]
                        </p>
                    }
                    @if (Model.Current.CurrentPeriodEnd != null)
                    {
                        <p class="text-muted mb-1">
                            @SharedLocalizer["Billing.Manage.NextBilling"]: @Model.Current.CurrentPeriodEnd.Value.ToLocalTime().ToString("yyyy-MM-dd")
                        </p>
                    }
                    @if (Model.Current.Status == SubscriptionStatus.Trial && Model.TrialEndsAt != null)
                    {
                        <p class="text-muted mb-1">@SharedLocalizer["Billing.Manage.TrialEnds"]: @Model.TrialEndsAt.Value.ToLocalTime().ToString("yyyy-MM-dd")</p>
                    }
                    @if (Model.Current.CancelledAt != null)
                    {
                        <div class="alert alert-warning mt-2 mb-0">@SharedLocalizer["Billing.Manage.CancelScheduled"]</div>
                    }
                }
                else
                {
                    <p class="text-muted">@SharedLocalizer["Billing.Manage.NoPlan"]</p>
                    <a asp-action="Index" class="btn btn-primary">@SharedLocalizer["Billing.ChoosePlan.Title"]</a>
                }

                @if (!Model.IsDealer)
                {
                    <p class="mt-3 mb-0">
                        <i class="fa fa-receipt me-1 text-primary"></i>
                        @string.Format(SharedLocalizer["Billing.Manage.PerPostCredits"].Value, Model.PerPostCredits)
                    </p>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-section-card h-100" style="max-width:none;">
                <h3 class="fw-bold mb-3">@SharedLocalizer["Billing.Manage.Actions"]</h3>
                <div class="d-grid gap-2">
                    @if (Model.HasStripeCustomer)
                    {
                        <form asp-action="UpdatePaymentMethod" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-primary w-100">
                                <i class="fa fa-credit-card me-2"></i>@SharedLocalizer["Billing.Manage.UpdateCard"]
                            </button>
                        </form>
                    }
                    @if (Model.Current != null && Model.Current.Status == SubscriptionStatus.Active
                         && Model.Current.CancelledAt == null
                         && !string.IsNullOrEmpty(Model.Current.StripeSubscriptionId))
                    {
                        <form asp-action="CancelSubscription" method="post"
                              data-confirm="@SharedLocalizer["Billing.Manage.CancelConfirm"]">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="fa fa-ban me-2"></i>@SharedLocalizer["Billing.Manage.Cancel"]
                            </button>
                        </form>
                    }
                    <div class="text-muted small mt-2">
                        @SharedLocalizer["Billing.Manage.LifetimePaid"]:
                        <strong>@Model.LifetimePaidJod.ToString("0.###") @SharedLocalizer["Common.JOD"]</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-section-card" style="max-width:none;">
        <h3 class="fw-bold mb-3">@SharedLocalizer["Billing.Manage.History"]</h3>
        @if (Model.History.Count == 0)
        {
            <p class="text-muted mb-0">@SharedLocalizer["Billing.Manage.NoHistory"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>@SharedLocalizer["Billing.History.Date"]</th>
                            <th>@SharedLocalizer["Billing.History.Type"]</th>
                            <th>@SharedLocalizer["Billing.History.Amount"]</th>
                            <th>@SharedLocalizer["Billing.History.Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.History)
                        {
                            <tr>
                                <td>@t.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@SharedLocalizer[$"Billing.Type.{t.Type}"]</td>
                                <td>@t.AmountJod.ToString("0.###") @SharedLocalizer["Common.JOD"]</td>
                                <td>@t.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
