@using CarFitProject.ViewModel
@using CarFitProject.Models.Subscriptions
@model PlanSelectionViewModel
@{
    ViewData["Title"] = SharedLocalizer["Billing.ChoosePlan.Title"].Value;

    string IntervalLabel(PlanBillingInterval i) => i switch
    {
        PlanBillingInterval.Week => SharedLocalizer["Billing.Interval.Week"].Value,
        PlanBillingInterval.Month => SharedLocalizer["Billing.Interval.Month"].Value,
        PlanBillingInterval.Year => SharedLocalizer["Billing.Interval.Year"].Value,
        _ => SharedLocalizer["Billing.Interval.PerPost"].Value
    };
}

<div class="container py-5">
    
    

    <div class="page-hero mb-4">
        <span class="eyebrow"><i class="fa fa-crown me-1"></i> @SharedLocalizer["Billing.Eyebrow"]</span>
        <h1 class="mb-1">@SharedLocalizer["Billing.ChoosePlan.Title"]</h1>
        <p class="lead mb-0">@SharedLocalizer["Billing.ChoosePlan.Subtitle"]</p>
    </div>

    @if (Model.Current != null && Model.Current.Status == SubscriptionStatus.Active)
    {
        <div class="alert alert-info d-flex justify-content-between align-items-center">
            <span><i class="fa fa-circle-check me-2"></i>@SharedLocalizer["Billing.AlreadyActive"]</span>
            <a asp-action="Manage" class="btn btn-sm btn-outline-primary">@SharedLocalizer["Billing.ManageLink"]</a>
        </div>
    }

    @if (Model.IsDealer)
    {
        <div class="row g-3">
            @foreach (var plan in Model.Plans.Where(p => p.BillingInterval != PlanBillingInterval.OneTime))
            {
                <div class="col-md-4">
                    <div class="form-section-card h-100 text-center" style="max-width:none;">
                        <h3 class="fw-bold">@plan.Name</h3>
                        <div class="display-6 fw-bold my-3">
                            @plan.AmountJod.ToString("0.###") <span class="fs-6 text-muted">@SharedLocalizer["Common.JOD"]</span>
                        </div>
                        <div class="text-muted mb-3">/ @IntervalLabel(plan.BillingInterval)</div>
                        <form asp-action="Subscribe" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="planCode" value="@plan.PlanCode" />
                            <button type="submit" class="btn btn-primary w-100 fw-bold">
                                @SharedLocalizer["Billing.Subscribe"]
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-section-card h-100" style="max-width:none;">
                    <h3 class="fw-bold"><i class="fa fa-gift me-2 text-primary"></i>@SharedLocalizer["Billing.Trial.Title"]</h3>
                    <p class="text-muted">@SharedLocalizer["Billing.Trial.Desc"]</p>
                    @if (Model.TrialActive)
                    {
                        <div class="alert alert-success mb-0">
                            @string.Format(SharedLocalizer["Billing.Trial.ActiveUntil"].Value, Model.TrialEndsAt?.ToLocalTime().ToString("yyyy-MM-dd"))
                        </div>
                    }
                    else if (!Model.TrialStarted)
                    {
                        <form asp-action="StartTrial" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary fw-bold">@SharedLocalizer["Billing.Trial.Start"]</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-secondary mb-0">@SharedLocalizer["Billing.Trial.Ended"]</div>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-section-card h-100" style="max-width:none;">
                    <h3 class="fw-bold"><i class="fa fa-receipt me-2 text-primary"></i>@SharedLocalizer["Billing.PerPost.Title"]</h3>
                    <div class="display-6 fw-bold my-3">
                        @Model.PerPostJod.ToString("0.###") <span class="fs-6 text-muted">@SharedLocalizer["Common.JOD"]</span>
                        <span class="fs-6 text-muted">/ @SharedLocalizer["Billing.Interval.PerPost"]</span>
                    </div>
                    <p class="text-muted">@SharedLocalizer["Billing.PerPost.Desc"]</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <form asp-action="Subscribe" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="planCode" value="USER_PAYPERPOST" />
                            <button type="submit" class="btn btn-primary fw-bold">
                                <i class="fa fa-credit-card me-1"></i>@SharedLocalizer["Billing.PerPost.Pay"]
                            </button>
                        </form>
                        <a asp-area="Seller" asp-controller="Inventory" asp-action="Form" class="btn btn-outline-primary">
                            @SharedLocalizer["Billing.PerPost.GoPost"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="text-center mt-4">
        <a asp-action="Manage" class="text-decoration-none">@SharedLocalizer["Billing.ManageLink"] <i class="fa fa-arrow-right ms-1"></i></a>
    </div>
</div>
