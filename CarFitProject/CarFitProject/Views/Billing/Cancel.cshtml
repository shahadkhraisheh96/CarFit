@{
    ViewData["Title"] = SharedLocalizer["Billing.Cancelled.Title"].Value;
}
<div class="container py-5 text-center" style="max-width:560px;">
    <div class="form-section-card" style="max-width:none;">
        <i class="fa fa-circle-xmark text-secondary" style="font-size:3rem;"></i>
        <h1 class="mt-3">@SharedLocalizer["Billing.Cancelled.Title"]</h1>
        <p class="lead text-muted">@SharedLocalizer["Billing.Cancelled.Body"]</p>
        <a asp-action="Index" class="btn btn-primary mt-2">@SharedLocalizer["Billing.ChoosePlan.Title"]</a>
    </div>
</div>
