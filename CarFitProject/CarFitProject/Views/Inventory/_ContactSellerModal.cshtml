@using CarFitProject.Helpers
@model CarFitProject.Models.CarListing
@{
    var seller = Model.Seller;
    var isPrivateSeller = string.Equals(seller?.Type, "Private", StringComparison.OrdinalIgnoreCase);
    var waNum = PhoneHelper.ToWaMeNumber(seller?.Phone);
    // Pre-filled WhatsApp message, localized: "{Year} {Make} {Model}".
    var prefill = string.Format(L["Detail.Buy.WhatsAppPrefill"].Value, Model.Car?.Year, Model.Car?.Make, Model.Car?.Model);
    var waLink = waNum == null ? null : $"https://wa.me/{waNum}?text=" + Uri.EscapeDataString(prefill);
}
<div class="modal fade" id="contactSellerModal" tabindex="-1" aria-hidden="true" aria-labelledby="contactSellerTitle">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="contactSellerTitle">
                    <i class="fa fa-handshake me-2 text-primary"></i>@L["Detail.Buy.ModalTitle"]
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@L["Detail.Buy.Close"]"></button>
            </div>
            <div class="modal-body">
                @if (seller != null)
                {
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h5 class="fw-bold mb-0">@seller.Name</h5>
                        <span class="badge @(isPrivateSeller ? "bg-info text-dark" : "bg-primary")">
                            @(isPrivateSeller ? L["Detail.Role.User"] : L["Detail.Role.Dealer"])
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(seller.Phone))
                    {
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <span class="fw-semibold" dir="ltr"><i class="fa fa-phone me-2 text-primary"></i>@seller.Phone</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-copy-phone="@seller.Phone" title="@L["Detail.CopyPhone"]" aria-label="@L["Detail.CopyPhone"]">
                                <i class="fa fa-copy"></i>
                            </button>
                        </div>
                    }

                    <div class="d-grid gap-2">
                        @if (waNum != null)
                        {
                            <a href="tel:+@waNum" class="btn btn-outline-primary fw-bold">
                                <i class="fa fa-phone me-2"></i>@L["Detail.CallSeller"]
                            </a>
                            <a href="@waLink" target="_blank" rel="noopener" class="btn btn-success fw-bold">
                                <i class="fa-brands fa-whatsapp me-2"></i>@L["Detail.WhatsApp"]
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(seller.Email))
                        {
                            <a href="mailto:@seller.Email?subject=@Uri.EscapeDataString($"CarFit listing #{Model.Id}")" class="btn btn-outline-primary fw-bold">
                                <i class="fa fa-envelope me-2"></i>@L["Detail.Email"]
                            </a>
                        }
                        <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal" data-scroll-to="mechanicBooking">
                            <i class="fa fa-screwdriver-wrench me-2"></i>@L["Detail.Buy.RequestInspection"]
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
