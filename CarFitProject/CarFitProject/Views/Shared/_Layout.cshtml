@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "ar" : "en";
    var dir = culture == "ar" ? "rtl" : "ltr";
    var bootstrapCss = culture == "ar"
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarFit</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    @if (culture == "ar")
    {
        <link rel="stylesheet" href="@bootstrapCss" crossorigin="anonymous" />
    }
    else
    {
        <link rel="stylesheet" href="@bootstrapCss" />
    }
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarFitProject.styles.css" asp-append-version="true" />
    <link href="~/css/style.css" rel="stylesheet" asp-append-version="true" />

    <style>
            /* 🛠️ COMPREHENSIVE POSITIONING MECHANICS */
            html, body {
                height: 100%;
                margin: 0;
                padding: 0;
            }

            body {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            .main-content-wrapper {
                flex: 1 0 auto;
            }

            /* 🏢 CORPORATE FOOTER STYLING ARCHITECTURE */
            .site-footer {
                flex-shrink: 0;
                background-color: #1e293b; /* Dark Slate theme matches admin styles */
                color: #94a3b8;
                border-top: 4px solid var(--primary, #0d6efd);
                font-size: 0.9rem;
            }

                .site-footer h5 {
                    color: #ffffff;
                    font-weight: 700;
                    font-size: 1.1rem;
                }

                .site-footer a {
                    color: #94a3b8;
                    transition: color 0.2s ease-in-out;
                }

                    .site-footer a:hover {
                        color: #ffffff !important;
                    }

            .footer-social-icon {
                width: 36px;
                height: 36px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                background-color: rgba(255, 255, 255, 0.05);
                color: #ffffff !important;
                transition: background-color 0.2s ease;
            }

                .footer-social-icon:hover {
                    background-color: var(--primary, #0d6efd);
                }

            .footer-bottom {
                background-color: #0f172a;
                color: #64748b;
                font-size: 0.8rem;
            }
    </style>
</head>
<body>
    <div class="main-content-wrapper">
        <header>
            <nav class="navbar navbar-expand-lg navbar-light sticky-top py-2 px-4">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center">
                    <h2 class="m-0"><i class="fa-solid fa-car-burst me-2"></i>CarFit</h2>
                </a>
                <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <div class="navbar-nav ms-auto py-3 py-lg-0">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-item nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">@Localizer["Nav.Home"]</a>
                        <a asp-area="" asp-controller="Inventory" asp-action="Search" class="nav-item nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Inventory" && ViewContext.RouteData.Values["Action"]?.ToString() == "Search" ? "active" : "") fw-semibold">@Localizer["Nav.Search"]</a>
                        <a asp-area="" asp-controller="Home" asp-action="About" class="nav-item nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")">@Localizer["Nav.About"]</a>
                        <a asp-area="" asp-controller="Inspection" asp-action="Index" class="nav-item nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Inspection" ? "active" : "")">@Localizer["Nav.Inspection"]</a>
                        <a asp-area="" asp-controller="Home" asp-action="Contact" class="nav-item nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Contact" ? "active" : "")">@Localizer["Nav.Contact"]</a>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-item nav-link fw-bold text-danger"><i class="fa-solid fa-shield-halved me-1"></i> @Localizer["Nav.AdminBase"]</a>
                            }
                            else if (User.IsInRole("Dealer"))
                            {
                                <a asp-area="Seller" asp-controller="Inventory" asp-action="Index" class="nav-item nav-link fw-bold text-success"><i class="fa-solid fa-building me-1"></i> @Localizer["Nav.SellerLot"]</a>
                            }
                            else if (User.IsInRole("Buyer"))
                            {
                                <a asp-area="Buyer" asp-controller="Dashboard" asp-action="Index" class="nav-item nav-link fw-bold text-primary"><i class="fa-solid fa-user-gear me-1"></i> @Localizer["Nav.BuyerHub"]</a>
                            }

                            <form class="form-inline d-flex align-items-center px-3" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="navLogoutForm">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-item nav-link border-0 bg-transparent text-uppercase fw-semibold text-secondary" style="cursor:pointer;"><i class="fa-solid fa-right-from-bracket me-1"></i>@Localizer["Nav.Logout"]</button>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="nav-item nav-link fw-bold">@Localizer["Nav.Login"]</a>
                            <a asp-area="Identity" asp-page="/Account/Register" class="nav-item nav-link fw-bold text-primary">@Localizer["Nav.Register"]</a>
                        }

                        <partial name="_LanguageSwitcher" />
                    </div>

                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Buyer"))
                    {
                        <a asp-area="Buyer" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary py-2 px-4 d-none d-lg-block">@Localizer["Nav.ViewMyFits"] <i class="fa fa-arrow-right ms-2"></i></a>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Inspection" asp-action="Book" class="btn btn-primary py-2 px-4 d-none d-lg-block">@Localizer["Nav.GetInspection"] <i class="fa fa-arrow-right ms-2"></i></a>
                    }
                </div>
            </nav>
        </header>

        <div class="container my-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>
    <footer class="site-footer pt-5">
        <div class="container pb-4">
            <div class="row g-4">
                <div class="col-12 col-md-4">
                    <h5 class="mb-3 text-white"><i class="fa-solid fa-car-burst text-primary me-2"></i>CarFit</h5>
                    <p class="small text-white-50 mb-3">
                        Empowering smart automotive choices in the local market with live inventory streams, transparent evaluation scorecards, and data-driven marketplace insights.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="footer-social-icon"><i class="fab fa-facebook-f text-white"></i></a>
                        <a href="#" class="footer-social-icon"><i class="fab fa-twitter text-white"></i></a>
                        <a href="#" class="footer-social-icon"><i class="fab fa-linkedin-in text-white"></i></a>
                        <a href="#" class="footer-social-icon"><i class="fab fa-instagram text-white"></i></a>
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <h5 class="mb-3 text-white">Marketplace</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a asp-area="" asp-controller="Inventory" asp-action="Search" class="text-decoration-none text-white-50">Search Vehicles</a></li>
                        <li><a asp-area="" asp-controller="Inspection" asp-action="Index" class="text-decoration-none text-white-50">Inspection Hub</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="About" class="text-decoration-none text-white-50">About Company</a></li>
                    </ul>
                </div>

                <div class="col-6 col-md-2">
                    <h5 class="mb-3 text-white">Support</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small">
                        <li><a asp-area="" asp-controller="Home" asp-action="Contact" class="text-decoration-none text-white-50">Help Desk</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-white-50">Privacy Terms</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-4">
                    <h5 class="mb-3 text-white">Contact Operations</h5>
                    <ul class="list-unstyled d-flex flex-column gap-2 small text-white-50">
                        <li><i class="fa-solid fa-location-dot me-2 text-primary"></i> <span class="text-white">Zarqa City Center Core, Jordan</span></li>
                        <li><i class="fa-solid fa-phone me-2 text-primary"></i> <span class="text-white">+962 7 XXXXXXXX</span></li>
                        <li><i class="fa-solid fa-envelope me-2 text-primary"></i> <span class="text-white">support@carfit.com</span></li>
                        <li><i class="fa-solid fa-clock me-2 text-primary"></i> Sunday &mdash; Saturday: 09:00 AM &mdash; 06:00 PM</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom py-3">
            <div class="container text-center text-white-50">
                &copy; @DateTime.Now.Year - <span class="text-white fw-medium">CarFit Project</span> &middot; All Rights Reserved. Development Team Integration Hub.
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>