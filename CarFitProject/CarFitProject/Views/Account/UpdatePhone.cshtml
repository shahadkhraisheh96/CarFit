@model CarFitProject.ViewModel.UpdatePhoneViewModel
@{
    ViewData["Title"] = L["Account.UpdatePhone.Title"].Value;
    var returnUrl = ViewBag.ReturnUrl as string;
    var isPlaceholder = (bool)(ViewBag.IsPlaceholder ?? false);
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="bg-white shadow-sm rounded-4 p-4 p-md-5">
                <h3 class="fw-bold mb-3"><i class="fa fa-phone text-primary me-2"></i>@L["Account.UpdatePhone.Title"]</h3>

                @if (isPlaceholder)
                {
                    <div class="alert alert-warning" role="alert">
                        <i class="fa fa-triangle-exclamation me-2"></i>@L["Account.UpdatePhone.Banner"]
                    </div>
                }

                <form asp-action="UpdatePhone" asp-route-returnUrl="@returnUrl" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="PhoneNumber" type="tel" class="form-control border-2" dir="ltr" placeholder="07XXXXXXXX" autocomplete="tel" aria-required="true" />
                        <label asp-for="PhoneNumber" class="fw-bold text-secondary">@SharedLocalizer["Phone number"]</label>
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2">
                        <i class="fa fa-check me-2"></i>@L["Account.UpdatePhone.Save"]
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="SkipPhoneUpdate" asp-route-returnUrl="@returnUrl" class="text-muted small text-decoration-none">
                        @L["Account.UpdatePhone.Skip"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
